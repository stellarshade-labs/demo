ags":[],"type":"text","url":"/docs/sdk#helpers","content":"The delivery adapters, if you need them directly"},"968":{"id":"sdk-116","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#shadecrypto","content":"The primitives, if you're not using the SDK:"},"969":{"id":"sdk-117","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"All six exported types work in **raw bytes** (`Uint8Array`), not hex strings:"},"970":{"id":"sdk-118","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`@shade/crypto`"},"971":{"id":"sdk-119","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`@shade/sdk`"},"972":{"id":"sdk-120","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"Encoding"},"973":{"id":"sdk-121","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`Uint8Array` (raw bytes)"},"974":{"id":"sdk-122","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`string` (hex)"},"975":{"id":"sdk-123","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"Fields"},"976":{"id":"sdk-124","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`spendPrivKey`, `viewPrivKey`, `metaAddress` (an object)"},"977":{"id":"sdk-125","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`metaAddress` (a `shade:stellar:` string), `spendPubKey`, `spendPrivKey`, `viewPubKey`, `viewPrivKey`"},"978":{"id":"sdk-126","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"`StealthClient.keygen()` returns the **SDK** shape; `generateMetaAddress()` returns the **crypto*&#x2A; shape. Passing one where the other is expected will not type-check. Convert the crypto shape with the exported &#x2A;*`stealthKeysFromRaw(raw)`*&#x2A; helper, and import the crypto type under a distinct name via the re-export &#x2A;*`RawStealthKeys`**, so mixed-use code has one unambiguous import site. </Callout>"},"979":{"id":"sdk-127","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#types","content":"Errors: `InvalidPublicKey`, `InvalidScalar`, `InvalidMetaAddress`, `PointAtInfinity`."},"980":{"id":"sdk-128","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#next-steps","content":"Core Concepts — the math behind these functions"},"981":{"id":"sdk-129","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#next-steps","content":"Delivery Methods — what `method` changes"},"982":{"id":"sdk-130","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#next-steps","content":"Relayer — the service `RelayerClient` talks to"},"983":{"id":"sdk-131","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#next-steps","content":"FAQ & Troubleshooting — error-by-error fixes"},"984":{"id":"security","page_id":"security","type":"page","content":"Security","breadcrumbs":["Documentation","Trust"],"tags":[],"url":"/docs/security"},"985":{"id":"security-0","page_id":"security","tags":[],"type":"text","url":"/docs/security","content":"Shade's threat model: what stealth addresses protect, what they explicitly do not hide, key-management assumptions, audit status and known limitations."},"986":{"id":"security-1","page_id":"security","type":"heading","tags":[],"url":"/docs/security#status-pre-audit--not-for-mainnet","content":"Status: pre-audit — not for mainnet"},"987":{"id":"security-2","page_id":"security","type":"heading","tags":[],"url":"/docs/security#threat-model","content":"Threat model"},"988":{"id":"security-3","page_id":"security","type":"heading","tags":[],"url":"/docs/security#what-shade-protects","content":"What Shade protects"},"989":{"id":"security-4","page_id":"security","type":"heading","tags":[],"url":"/docs/security#what-shade-does-not-protect","content":"What Shade does NOT protect"},"990":{"id":"security-5","page_id":"security","type":"heading","tags":[],"url":"/docs/security#key-management-assumptions","content":"Key-management assumptions"},"991":{"id":"security-6","page_id":"security","type":"heading","tags":[],"url":"/docs/security#the-raw-scalar-footgun","content":"The raw-scalar footgun"},"992":{"id":"security-7","page_id":"security","type":"heading","tags":[],"url":"/docs/security#wallet-derived-keys-an-accepted-trade-off","content":"Wallet-derived keys: an accepted trade-off"},"993":{"id":"security-8","page_id":"security","type":"heading","tags":[],"url":"/docs/security#no-view-key-revocation","content":"No view-key revocation"},"994":{"id":"security-9","page_id":"security","type":"heading","tags":[],"url":"/docs/security#cryptographic-notes","content":"Cryptographic notes"},"995":{"id":"security-10","page_id":"security","type":"heading","tags":[],"url":"/docs/security#known-limitations-and-open-risks","content":"Known limitations and open risks"},"996":{"id":"security-11","page_id":"security","type":"heading","tags":[],"url":"/docs/security#protocol--product","content":"Protocol / product"},"997":{"id":"security-12","page_id":"security","type":"heading","tags":[],"url":"/docs/security#implementation-gaps-worth-knowing","content":"Implementation gaps worth knowing"},"998":{"id":"security-13","page_id":"security","type":"heading","tags":[],"url":"/docs/security#user-responsibility","content":"User responsibility"},"999":{"id":"security-14","page_id":"security","type":"heading","tags":[],"url":"/docs/security#reporting","content":"Reporting"},"1000":{"id":"security-15","page_id":"security","type":"heading","tags":[],"url":"/docs/security#next-steps","content":"Next steps"},"1001":{"id":"security-16","page_id":"security","tags":[],"type":"text","url":"/docs/security","content":"\\{/\\* adapted from shade\\@36217c4 docs/09-security.md \\*/}"},"1002":{"id":"security-17","page_id":"security","tags":[],"type":"text","url":"/docs/security","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"1003":{"id":"security-18","page_id":"security","tags":[],"type":"text","url":"/docs/security","content":"What Shade protects, what it explicitly does not, and what you must not rely on yet. Read this page before putting value at risk."},"1004":{"id":"security-19","page_id":"security","tags":[],"type":"text","url":"/docs/security#status-pre-audit--not-for-mainnet","content":"The protocol and this implementation have **not undergone an external cryptographic audit**. An audit is on the roadmap. Treat the library as production-track but pre-audit, and **do not handle mainnet value**."},"1005":{"id":"security-20","page_id":"security","tags":[],"type":"text","url":"/docs/security#status-pre-audit--not-for-mainnet","content":"Day-to-day development and testing run on the Docker local network. The **pool** method has been validated end-to-end on Stellar **testnet** (2026-07-17): deposit → scan → balance → direct withdraw → relayer fee-bumped withdraw, for both native XLM and a classic-asset (USDC) SAC. No testnet contract id is pinned (testnet resets quarterly — deploy your own). The **account** method is unexercised at public-network scale: its scan (and `balance`) walk the global Horizon transaction feed, so a cold scan for a fresh recipient is impractical there — a Horizon indexer is the roadmap fix."},"1006":{"id":"security-21","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"Property"},"1007":{"id":"security-22","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"How"},"1008":{"id":"security-23","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Recipient identity**"},"1009":{"id":"security-24","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"A stealth address is unlinkable to a meta-address without the view key. An observer sees `sender → contract` (pool) or `sender → one-time account` (account), plus `R` and `stealth_pk`, none of which reveal *you*."},"1010":{"id":"security-25","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Unlinkability between payments**"},"1011":{"id":"security-26","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"Each payment uses a fresh random ephemeral `r`, so two stealth addresses for the same recipient look unrelated."},"1012":{"id":"security-27","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Your funded accounts**"},"1013":{"id":"security-28","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"A relayer fee-bump means your own wallet never appears on the withdrawal."},"1014":{"id":"security-29","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Spend/view separation**"},"1015":{"id":"security-30","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"The view key can find payments but never move them — safe to delegate to a scanner."},"1016":{"id":"security-31","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Replay across deployments/networks**"},"1017":{"id":"security-32","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"The withdraw message binds the contract address **and** the network id, so a signature valid on one deployment is rejected on another."},"1018":{"id":"security-33","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Replay of the same withdrawal**"},"1019":{"id":"security-34","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"A strictly-increasing per-key nonce in contract storage."},"1020":{"id":"security-35","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Reentrancy on withdraw**"},"1021":{"id":"security-36","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"Checks-effects-interactions: nonce and balance are committed before the external SAC `transfer`."},"1022":{"id":"security-37","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Small-subgroup attacks**"},"1023":{"id":"security-38","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"`validatePoint` accepts only on-curve, **torsion-free** points, rejecting the identity and small-order points on every path that touches `R`, `K_view`, `K_spend`."},"1024":{"id":"security-39","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Announcement spam**"},"1025":{"id":"security-40","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"Deposit and announcement are atomic — no deposit, no announcement."},"1026":{"id":"security-41","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Malicious relayer (sponsored claim)**"},"1027":{"id":"security-42","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"The client re-derives the expected operation list from its own trusted inputs and refuses to sign a mismatch (`SponsoredClaimMismatchError`)."},"1028":{"id":"security-43","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"**Tampered session storage**"},"1029":{"id":"security-44","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-protects","content":"On unlock, public keys are re-derived from the decrypted private scalars and compared (`SessionIntegrityError`)."},"1030":{"id":"security-45","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Not protected"},"1031":{"id":"security-46","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Why"},"1032":{"id":"security-47","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Amounts**"},"1033":{"id":"security-48","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Deposit and withdrawal amounts are public on-chain."},"1034":{"id":"security-49","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**The fact a payment occurred**"},"1035":{"id":"security-50","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Fully visible."},"1036":{"id":"security-51","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Fund flow**"},"1037":{"id":"security-52","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Shade is not a mixer.** A pool deposit and its withdrawal both name the same `stealth_pk`, so the flow is traceable. Only the link to your identity is hidden."},"1038":{"id":"security-53","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Timing correlation**"},"1039":{"id":"security-54","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Withdraw immediately after a deposit and the link is obvious."},"1040":{"id":"security-55","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Amount-pattern correlation**"},"1041":{"id":"security-56","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Distinctive amounts correlate deposits and withdrawals."},"1042":{"id":"security-57","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**The withdrawal destination**"},"1043":{"id":"security-58","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Public — though it can be a fresh address with no history."},"1044":{"id":"security-59","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"**Your behaviour**"},"1045":{"id":"security-60","page_id":"security","tags":[],"type":"text","url":"/docs/security#what-shade-does-not-protect","content":"Address reuse, a linked fee-payer, or a known destination will deanonymize you regardless of the cryptography."},"1046":{"id":"security-61","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**Spend private keys never leave the client.**"},"1047":{"id":"security-62","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**View keys enable scan-only access** — safe to delegate, but see the revocation limit below."},"1048":{"id":"security-63","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**Stealth private keys exist only in memory** during a claim/withdraw."},"1049":{"id":"security-64","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**All randomness** comes from the platform CSPRNG (`crypto.getRandomValues()` / `randomBytes`)."},"1050":{"id":"security-65","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**Keystores are encrypted by default** with AES-256-GCM (scrypt `N=131072, r=8, p=1`, files mode `0600`); `--plaintext` opts out."},"1051":{"id":"security-66","page_id":"security","tags":[],"type":"text","url":"/docs/security#key-management-assumptions","content":"**Browser sessions** use PBKDF2-SHA256 (600k) → AES-256-GCM; only public keys are stored in the clear."},"1052":{"id":"security-67","page_id":"security","tags":[],"type":"text","url":"/docs/security#wallet-derived-keys-an-accepted-trade-off","content":"With the wallet-signature path, **wallet compromise equals stealth-key compromise** — anyone who can produce the signature can re-derive the keys. That is the accepted deal for keyless recovery."},"1053":{"id":"security-68","page_id":"security","tags":[],"type":"text","url":"/docs/security#wallet-derived-keys-an-accepted-trade-off","content":"Two hard rules:"},"1054":{"id":"security-69","page_id":"security","tags":[],"type":"text","url":"/docs/security#wallet-derived-keys-an-accepted-trade-off","content":"**Never sign the derivation message anywhere you don't trust.** Signing it hands over the ability to derive (and control) your stealth keys. The message includes an explicit warning line for exactly this reason."},"1055":{"id":"security-70","page_id":"security","tags":[],"type":"text","url":"/docs/security#wallet-derived-keys-an-accepted-trade-off","content":"**The signer must be deterministic** (RFC 8032). A randomized signer derives different, unrecoverable keys on every call. The SDK verifies determinism by default (signs twice and compares) rather than letting you find out later."},"1056":{"id":"security-71","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**Curve:** ed25519, order `L = 2^252 + 27742317777372353535851937790883648493`."},"1057":{"id":"security-72","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**Primitives:** `@noble/curves` / `@noble/hashes` — the same audited primitives used broadly across the Stellar ecosystem — plus `@scure/bip39`."},"1058":{"id":"security-73","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**The ECDH runs client-side by necessity.** Soroban's host exposes `ed25519_verify`, `sha256`, `secp256r1_verify`, and curve operations for **BLS12-381** (CAP-0059) and **BN254** — but **no Curve25519 scalar-multiplication host function**. The contract only ever *verifies* an ed25519 signature."},"1059":{"id":"security-74","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**No BIP-32/44.** HD derivation uses domain-separated SHA-256, not standard BIP-32 paths (those are defined over secp256k1). Recovery works within Shade's own scheme."},"1060":{"id":"security-75","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**Deterministic signing.** `signWithStealthKey` builds an RFC 8032-style signature directly from the raw scalar, with a deterministic nonce `r = SHA-512(scalar ‖ message) mod L`. Signatures verify with standard `ed25519.verify`."},"1061":{"id":"security-76","page_id":"security","tags":[],"type":"text","url":"/docs/security#cryptographic-notes","content":"**Amount encryption** (`encryptAmount` / `decryptAmount`) is encrypt-then-MAC (XOR keystream + HMAC-SHA256) with constant-time tag verification. It is **not used by the pool contract** — it exists for applications built on top."},"1062":{"id":"security-77","page_id":"security","tags":[],"type":"text","url":"/docs/security#protocol--product","content":"**Destination account must exist.** A pool withdrawal needs an active Stellar destination (its own \\~1 XLM reserve). Fund it via an exchange withdrawal for best privacy, or use a relayer-sponsored claim."},"1063":{"id":"security-78","page_id":"security","tags":[],"type":"text","url":"/docs/security#protocol--product","content":"**`spp` is not implemented** — a reserved slot that always throws."},"1064":{"id":"security-79","page_id":"security","tags":[],"type":"text","url":"/docs/security#protocol--product","content":"**No external audit.**"},"1065":{"id":"security-80","page_id":"security","tags":[],"type":"text","url":"/docs/security#implementation-gaps-worth-knowing","content":"**Relayer defaults are permissive.** `RELAYER_REQUIRE_CREDIT=0` leaves `/relay` and `/sponsor-claim/submit` unauthenticated; `CORS_ORIGIN` defaults to `*`; an unset `RELAYER_SECRET` boots an unfunded random keypair. See Relayer."},"1066":{"id":"security-81","page_id":"security","tags":[],"type":"text","url":"/docs/security#implementation-gaps-worth-knowing","content":"**Relayer state is single-node and non-durable.** The credit ledger is a JSON file (wiped by an ephemeral-filesystem restart, taking consumed-tx idempotency with it); challenge nonces and rate-limit buckets are in-memory."},"1067":{"id":"security-82","page_id":"security","tags":[],"type":"text","url":"/docs/security#implementation-gaps-worth-knowing","content":"**State archival.** If a `Balance`/`Nonce` entry archives, a withdraw over the archived footprint fails on-chain while `get_balance` still reports the funds. The SDK restores automatically; if the restore itself fails you get `EntryArchivedRestoringError` — **the funds are safe**, but the withdraw can't proceed until the entry is restored. Read-path TTL extension (`get_balance`/`get_nonce` bump a live entry back to \\~1 year) makes this unlikely for anyone who scans periodically."},"1068":{"id":"security-83","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"The cryptography gives you the tools; you can still deanonymize yourself:"},"1069":{"id":"security-84","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"**Vary timing.** Don't withdraw right after a deposit."},"1070":{"id":"security-85","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"**Vary amounts.** Partial withdrawals reduce correlation with the original deposit."},"1071":{"id":"security-86","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"**Use fresh destination addresses** with no history."},"1072":{"id":"security-87","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"**Never pay the fee from an account linked to you** — that's what the relayer is for."},"1073":{"id":"security-88","page_id":"security","tags":[],"type":"text","url":"/docs/security#user-responsibility","content":"**Guard your view key.** Sharing it is permanent."},"1074":{"id":"security-89","page_id":"security","tags":[],"type":"text","url":"/docs/security#reporting","content":"This project is pre-audit and provided as-is."},"1075":{"id":"security-90","page_id":"security","tags":[],"type":"text","url":"/docs/security#next-steps","content":"Core Concepts — the cryptography these guarantees rest on"},"1076":{"id":"security-91","page_id":"security","tags":[],"type":"text","url":"/docs/security#next-steps","content":"Architecture — where each control is implemented"},"1077":{"id":"security-92","page_id":"security","tags":[],"type":"text","url":"/docs/security#next-steps","content":"Relayer — operational hardening"},"1078":{"id":"security-93","page_id":"security","tags":[],"type":"text","url":"/docs/security#next-steps","content":"FAQ & Troubleshooting — what specific errors mean"}},"count":1078},"sorting":{"language":"english","sortableProperties":["content","page_id","type","url"],"sortablePropertiesWithTypes":{"content":"string","page_id":"string","type":"string","url":"string"},"sorts":{"content":{"docs":{"1":482,"2":885,"3":532,"4":965,"5":802,"6":920,"7":494,"8":997,"9":828,"10":915,"11":558,"12":845,"13":557,"14":1058,"15":751,"16":170,"17":679,"18":883,"19":105,"20":780,"21":848,"22":704,"23":231,"24":596,"25":166,"26":235,"27":410,"28":571,"29":230,"30":934,"31":563,"32":234,"33":619,"34":903,"35":278,"36":991,"37":898,"38":944,"39":658,"40":717,"41":803,"42":285,"43":1068,"44":493,"45":425,"46":1069,"47":602,"48":303,"49":814,"50":792,"51":304,"52":815,"53":555,"54"