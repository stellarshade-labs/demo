nt":"File"},"391":{"id":"cli-183","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"Contents"},"392":{"id":"cli-184","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"`<network>-contract`"},"393":{"id":"cli-185","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"The pool contract address"},"394":{"id":"cli-186","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"`horizon-cursor-<network>`"},"395":{"id":"cli-187","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"Account-method Horizon paging cursor"},"396":{"id":"cli-188","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"`horizon-payments-<network>.json`"},"397":{"id":"cli-189","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"Discovered account-method payments (deduplicated)"},"398":{"id":"cli-190","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#local-state","content":"The keystore itself defaults to `~/.shade-keys.json`."},"399":{"id":"cli-191","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#next-steps","content":"Getting Started: install and first run"},"400":{"id":"cli-192","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#next-steps","content":"Delivery Methods: what `--method` actually changes"},"401":{"id":"cli-193","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#next-steps","content":"SDK Reference: the programmatic equivalent"},"402":{"id":"cli-194","page_id":"cli","tags":[],"type":"text","url":"/docs/cli#next-steps","content":"FAQ & Troubleshooting: common command failures"},"403":{"id":"concepts","page_id":"concepts","type":"page","content":"Core Concepts","breadcrumbs":["Documentation","Learn"],"tags":[],"url":"/docs/concepts"},"404":{"id":"concepts-0","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts","content":"How stealth addresses work on Stellar: DKSAP, view and spend keys, meta-addresses, view tags, and the ed25519 math behind them."},"405":{"id":"concepts-1","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#two-keys-not-one","content":"Two keys, not one"},"406":{"id":"concepts-2","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#meta-address","content":"Meta-address"},"407":{"id":"concepts-3","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#stealth-address","content":"Stealth address"},"408":{"id":"concepts-4","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#ephemeral-key-r-and-shared-secret-s","content":"Ephemeral key (R) and shared secret (S)"},"409":{"id":"concepts-5","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#view-tag","content":"View tag"},"410":{"id":"concepts-6","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#the-math","content":"The math"},"411":{"id":"concepts-7","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#why-the-ecdh-runs-client-side","content":"Why the ECDH runs client-side"},"412":{"id":"concepts-8","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#getting-your-keys-four-ways","content":"Getting your keys: four ways"},"413":{"id":"concepts-9","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#announcement","content":"Announcement"},"414":{"id":"concepts-10","page_id":"concepts","type":"heading","tags":[],"url":"/docs/concepts#next-steps","content":"Next steps"},"415":{"id":"concepts-11","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts","content":"\\{/\\* adapted from shade\\@36217c4 docs/02-core-concepts.md \\*/}"},"416":{"id":"concepts-12","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"417":{"id":"concepts-13","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts","content":"Shade implements **DKSAP** (the Dual-Key Stealth Address Protocol) on ed25519. This page defines every term used across the rest of the docs, in plain English first, with the exact math underneath."},"418":{"id":"concepts-14","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"Most wallets have one key that does everything. Shade splits your identity into **two** key pairs, which is what makes safe scanning possible:"},"419":{"id":"concepts-15","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"**View key.** Lets someone *find* payments sent to you. It can **see** but **cannot spend**. Safe to hand to a phone, a server, or a watch-only scanning service."},"420":{"id":"concepts-16","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"**Spend key.** Required to actually *move* the money. This one never leaves you."},"421":{"id":"concepts-17","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"Each key has a public and a private half:"},"422":{"id":"concepts-18","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"The **public** spend + view keys go *into the meta-address you give out*, so a sender can do the math to create your one-time address."},"423":{"id":"concepts-19","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#two-keys-not-one","content":"The **private** spend + view keys stay *with you*: the private view key **detects** incoming payments, the private spend key **spends** them."},"424":{"id":"concepts-20","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#meta-address","content":"Your **meta-address** is the public halves of both keys, bundled and encoded:"},"425":{"id":"concepts-21","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#meta-address","content":"It is **not a Stellar account**: you cannot send funds to it directly. It is only an input a sender uses to *compute* a one-time address. Share it freely: profile, DM, business card."},"426":{"id":"concepts-22","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#stealth-address","content":"A **stealth address** is the one-time destination a sender derives from your meta-address. It's a normal Stellar `G...` address, but nobody can link it back to your meta-address without your view key."},"427":{"id":"concepts-23","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#stealth-address","content":"In the `pool` method the stealth address is never a real Stellar account. It's a **key** the contract uses to track your balance. In the `account` method it *is* a real, funded one-time account. See Delivery Methods."},"428":{"id":"concepts-24","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#ephemeral-key-r-and-shared-secret-s","content":"For every payment, the sender picks a fresh random scalar `r` and publishes `R = r·G` (the **ephemeral public key**). Both sides can then compute the same **shared secret** without talking to each other:"},"429":{"id":"concepts-25","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#ephemeral-key-r-and-shared-secret-s","content":"Sender: `S = r · K_view`"},"430":{"id":"concepts-26","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#ephemeral-key-r-and-shared-secret-s","content":"Receiver: `S = k_view · R`"},"431":{"id":"concepts-27","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#ephemeral-key-r-and-shared-secret-s","content":"This is **ECDH** (Elliptic Curve Diffie-Hellman): both parties arrive at the same `S` without it ever crossing the wire. `S` is what makes the stealth address derivable by you and nobody else."},"432":{"id":"concepts-28","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#view-tag","content":"The **view tag** is a single byte, `SHA256(S)[0]`, published alongside each announcement. It's a fast-path filter: if the tag doesn't match, the announcement definitely isn't yours and you can skip the rest of the check."},"433":{"id":"concepts-29","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#view-tag","content":"**What it saves.** For the \\~255/256 of announcements that don't match, the view tag lets a scanner skip the extra address-derivation step and move straight to the next announcement."},"434":{"id":"concepts-30","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#view-tag","content":"> Only the `pool` method uses view tags. The `account` method matches on the derived destination address directly, which *is* the full verification."},"435":{"id":"concepts-31","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"**Meta-address generation (receiver)**"},"436":{"id":"concepts-32","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Generate two random scalars `k_spend`, `k_view` ∈ `[0, L-1]`"},"437":{"id":"concepts-33","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Compute `K_spend = k_spend · G`, `K_view = k_view · G`"},"438":{"id":"concepts-34","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Meta-address = `(K_spend, K_view)`"},"439":{"id":"concepts-35","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"**Stealth address derivation (sender)**"},"440":{"id":"concepts-36","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Pick random ephemeral scalar `r`"},"441":{"id":"concepts-37","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`R = r · G`"},"442":{"id":"concepts-38","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`S = r · K_view`"},"443":{"id":"concepts-39","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`s = SHA256(S) mod L`"},"444":{"id":"concepts-40","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`P_stealth = K_spend + s · G`"},"445":{"id":"concepts-41","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`view_tag = SHA256(S)[0]`"},"446":{"id":"concepts-42","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"**Scanning (receiver)**"},"447":{"id":"concepts-43","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"For each announcement: `S = k_view · R`"},"448":{"id":"concepts-44","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Filter: does `SHA256(S)[0]` equal the published view tag?"},"449":{"id":"concepts-45","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"On a match: `P = K_spend + SHA256(S)·G`"},"450":{"id":"concepts-46","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Verify `P` equals the announced stealth address"},"451":{"id":"concepts-47","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"**Private key recovery (receiver)**"},"452":{"id":"concepts-48","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`S = k_view · R`"},"453":{"id":"concepts-49","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`s = SHA256(S) mod L`"},"454":{"id":"concepts-50","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"`p_stealth = k_spend + s mod L`"},"455":{"id":"concepts-51","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"**Curve parameters**"},"456":{"id":"concepts-52","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Curve: ed25519"},"457":{"id":"concepts-53","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#the-math","content":"Order: `L = 2^252 + 27742317777372353535851937790883648493`"},"458":{"id":"concepts-54","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#why-the-ecdh-runs-client-side","content":"Stellar's smart-contract environment doesn't offer the specific curve operation the ECDH needs, so that math runs **on your device**, not on-chain. The contract never sees your keys; it only checks a signature."},"459":{"id":"concepts-55","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**Random.** Fresh keys, back them up yourself."},"460":{"id":"concepts-56","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**BIP-39 mnemonic.** 12 words you write down; recover on any device."},"461":{"id":"concepts-57","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**HD derivation.** Deterministic, via domain-separated SHA-256."},"462":{"id":"concepts-58","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**From your wallet's signature.** Sign one fixed message with your Stellar wallet and Shade derives your stealth keys from that signature. Same wallet + same scope → the same keys every time, so there is nothing extra to store or back up. This is the \"keyless\" path."},"463":{"id":"concepts-59","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**Trade-off for method 4:** your wallet effectively *is* your stealth-key backup. If the wallet is compromised, so are the stealth keys. That is the accepted deal for keyless recovery. Also: never sign the derivation message anywhere you don't trust. Anyone who obtains that signature can derive (and thus control) your stealth keys."},"464":{"id":"concepts-60","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#getting-your-keys-four-ways","content":"**Key scoping.** The `appId` and `keyScope` are folded into the signed message, so different applications derive independent keys. They must **match across every tool** that derives from the same wallet, or you'll get different, non-interoperable keys. Defaults: `appId = 'default'`, `keyScope = 'stealth'` (SDK constants `DEFAULT_APP_ID` / `DEFAULT_KEY_SCOPE`; the CLI's `--app-id` / `--key-scope` default to the same values)."},"465":{"id":"concepts-61","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"An **announcement** is the on-chain record that lets you discover a payment. In the `pool` method it's a contract storage entry created **atomically with the deposit**: no deposit, no announcement, which makes announcement spam impossible. It carries:"},"466":{"id":"concepts-62","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"Field"},"467":{"id":"concepts-63","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"Meaning"},"468":{"id":"concepts-64","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`ephemeral_pk`"},"469":{"id":"concepts-65","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"The 32-byte `R`"},"470":{"id":"concepts-66","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`view_tag`"},"471":{"id":"concepts-67","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"The one-byte fast-path filter (stored as `u32`)"},"472":{"id":"concepts-68","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`stealth_pk`"},"473":{"id":"concepts-69","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"The 32-byte derived stealth public key"},"474":{"id":"concepts-70","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`token`"},"475":{"id":"concepts-71","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"The SAC token address that was deposited"},"476":{"id":"concepts-72","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`amount`"},"477":{"id":"concepts-73","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"Amount deposited, in the token's smallest unit"},"478":{"id":"concepts-74","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"`sequence`"},"479":{"id":"concepts-75","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"Ledger sequence at deposit time"},"480":{"id":"concepts-76","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#announcement","content":"In the `account` method there is no contract announcement: the ephemeral key `R&#x60; rides in the transaction's &#x2A;*`MemoHash`**, and discovery means paging Horizon."},"481":{"id":"concepts-77","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#next-steps","content":"Architecture: how these concepts map onto components"},"482":{"id":"concepts-78","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#next-steps","content":"Delivery Methods: where `pool` and `account` differ"},"483":{"id":"concepts-79","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#next-steps","content":"SDK Reference: the functions that implement all of this"},"484":{"id":"concepts-80","page_id":"concepts","tags":[],"type":"text","url":"/docs/concepts#next-steps","content":"Security: what the cryptography does and does not guarantee"},"485":{"id":"delivery-methods","page_id":"delivery-methods","type":"page","content":"Delivery Methods","breadcrumbs":["Documentation","Learn"],"tags":[],"url":"/docs/delivery-methods"},"486":{"id":"delivery-methods-0","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods","content":"Compare Shade's delivery methods: the Soroban pool contract versus a direct one-time Stellar account. Where funds sit, what they cost, and how you claim them."},"487":{"id":"delivery-methods-1","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#the-two-methods","content":"The two methods"},"488":{"id":"delivery-methods-2","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#pool--the-soroban-contract","content":"Pool — The Soroban contract"},"489":{"id":"delivery-methods-3","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#account--a-direct-one-time-account","content":"Account — A direct one-time account"},"490":{"id":"delivery-methods-4","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#discovery-and-the-announcement-indexer","content":"Discovery and the announcement indexer"},"491":{"id":"delivery-methods-5","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#native-xlm","content":"Native XLM"},"492":{"id":"delivery-methods-6","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Tokens (USDC and friends)"},"493":{"id":"delivery-methods-7","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#auto--letting-the-client-choose","content":"Auto — Letting the client choose"},"494":{"id":"delivery-methods-8","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#choosing","content":"Choosing"},"495":{"id":"delivery-methods-9","page_id":"delivery-methods","type":"heading","tags":[],"url":"/docs/delivery-methods#next-steps","content":"Next steps"},"496":{"id":"delivery-methods-10","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods","content":"\\{/\\* adapted from shade\\@36217c4 docs/04-delivery-methods.md \\*/}"},"497":{"id":"delivery-methods-11","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"498":{"id":"delivery-methods-12","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods","content":"The same meta-address works with more than one \"delivery method,\" the mechanism that actually carries money to the recipient. They differ in where funds sit, what they cost, and how you claim them. This page compares them and tells you which to pick."},"499":{"id":"delivery-methods-13","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"`DeliveryMethod = 'pool' | 'account'`"},"500":{"id":"delivery-methods-14","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**pool**"},"501":{"id":"delivery-methods-15","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**account**"},"502":{"id":"delivery-methods-16","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Where funds sit**"},"503":{"id":"delivery-methods-17","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Shared Soroban **pool contract**, keyed by your stealth key"},"504":{"id":"delivery-methods-18","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"A one-time real Stellar **account** / claimable balance"},"505":{"id":"delivery-methods-19","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**New account created?**"},"506":{"id":"delivery-methods-20","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**No** (no \\~1 XLM reserve locked)"},"507":{"id":"delivery-methods-21","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Yes** (\\~1 XLM base reserve required)"},"508":{"id":"delivery-methods-22","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Assets**"},"509":{"id":"delivery-methods-23","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Any SAC token (XLM, USDC, …)"},"510":{"id":"delivery-methods-24","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Native XLM, or any classic/SAC asset (as a claimable balance)"},"511":{"id":"delivery-methods-25","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Discovery**"},"512":{"id":"delivery-methods-26","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Contract **announcements** + **view-tag** fast path (\\~2×)"},"513":{"id":"delivery-methods-27","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Horizon** paging for the ephemeral key in a `MemoHash`, then destination match (no view tag); an optional **announcement indexer** makes cold scans fast"},"514":{"id":"delivery-methods-28","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Claim**"},"515":{"id":"delivery-methods-29","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Signature-verified `withdraw`, **no Stellar account needed**"},"516":{"id":"delivery-methods-30","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Sign with the recovered stealth key, or a relayer-sponsored payout"},"517":{"id":"delivery-methods-31","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Cost profile**"},"518":{"id":"delivery-methods-32","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"Soroban invocation fee only (no reserve)"},"519":{"id":"delivery-methods-33","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"1 XLM reserve (native, reclaimed on sweep) or 1.5001 XLM fronted (token, 0.5 returns to sender)"},"520":{"id":"delivery-methods-34","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#the-two-methods","content":"**Rule of thumb:** both methods give you the same identity privacy, so choose on cost and tooling. For native XLM there's little between them, since the account-method reserve is reclaimed when you sweep. `pool` pulls ahead on tokens: an `account` token send makes the sender front \\~1.5 XLM (0.5 comes back on claim), while `pool` costs only the Soroban fee. But `pool` is also the easier method to undo your own privacy with: a relayed pool withdraw hides only the fee-payer, so use a throwaway fee-payer per withdraw (or the `account` sponsored claim). `account` is the simplest path with vanilla Horizon tooling."},"521":{"id":"delivery-methods-35","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"Money is deposited into the pool contract and tracked under `Balance(stealth_pk, token)`. No Stellar account is ever created for the stealth key, so **no \\~1 XLM MBR is locked**."},"522":{"id":"delivery-methods-36","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"The deposit and its announcement are written **atomically** (no deposit, no announcement), which makes announcement spam impossible."},"523":{"id":"delivery-methods-37","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"**Claiming** calls `withdraw(...)` with an ed25519 signature over the withdraw message. Because authorization is a signature rather than `require_auth`, *anyone* can submit the transaction for you. Two ways to pay the Soroban fee:"},"524":{"id":"delivery-methods-38","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"**Direct:** you supply a fee-payer account and submit to RPC yourself."},"525":{"id":"delivery-methods-39","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"**Relayer fee-bump:** POST to the relayer's `/relay`, and it fee-bumps the transaction. See Relayer."},"526":{"id":"delivery-methods-40","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"You may withdraw the **full balance or a partial amount** (`opts.amount`)."},"527":{"id":"delivery-methods-41","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"**Requirements and caveats**"},"528":{"id":"delivery-methods-42","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"`contractId` is **required** whenever the pool method is enabled; there is no built-in default. A `testnet` client with pool enabled and no explicit `contractId` throws `ContractIdRequiredError`."},"529":{"id":"delivery-methods-43","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"The withdrawal **destination must be an existing Stellar account** (it needs its own reserve to exist)."},"530":{"id":"delivery-methods-44","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#pool--the-soroban-contract","content":"**Not a mixer.** The deposit and the withdraw both name the same `stealth_pk` on-chain, so the *flow* remains traceable; only the link to your identity is hidden."},"531":{"id":"delivery-methods-45","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#account--a-direct-one-time-account","content":"Money goes to a real, one-time Stellar account. The ephemeral key `R` travels in the transaction's 32-byte `MemoHash`; discovery derives the stealth address from `(k_view, R)` and looks for an operation whose destination matches. That destination match **is** the full DKSAP verification, so no view tag is needed."},"532":{"id":"delivery-methods-46","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#account--a-direct-one-time-account","content":"**For developers.** `normalizeDestination` in `packages/sdk/src/methods/account.ts`, via `MuxedAccount.fromAddress(address, '0').baseAccount().accountId()`. Note this normalizes for **matching only**: Shade never *derives* a muxed stealth address; the sender always creates a plain `G...` one-time account. </Callout>"},"533":{"id":"delivery-methods-47","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#discovery-and-the-announcement-indexer","content":"Because there is no view tag, **every hash-memo transaction on the network is a discovery candidate**. An unassisted scan walks the global Horizon transaction feed client-side, which makes a cold scan for a fresh recipient take minutes (and grow with the network). The fix is the **announcement indexer** (`packages/indexer`): a standalone service that walks the feed server-side **once for everyone**, keeps only hash-memo candidates with their operations, and serves them as a compact feed the client filters **locally**. It deliberately answers no address- or R-keyed queries, so the operator cannot link keys to requests. Point the SDK at one with `ClientConfig.indexerUrl`, or the CLI with `--indexer` / `SHADE_INDEXER`."},"534":{"id":"delivery-methods-48","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#discovery-and-the-announcement-indexer","content":"**Trust model:** the indexer can *hide* payments but cannot *fabricate* them. The client derives the stealth address from `R` itself, and everything is re-verified on-chain at claim. Horizon remains the source of truth: the scan falls back to the pure Horizon walk automatically when the indexer is unreachable, unhealthy, or faults mid-scan, and it **always finishes with a Horizon tail** so indexer lag cannot hide a payment."},"535":{"id":"delivery-methods-49","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#discovery-and-the-announcement-indexer","content":"**One caveat to know:** with an indexer configured, a **cold** scan (no saved cursor) fast-starts at the indexer's coverage start rather than genesis. A payment older than the indexer's coverage is found only by the exhaustive walk: CLI `--full-rescan`, SDK `ScanOpts.exhaustive`. See Architecture → The announcement indexer for endpoints, configuration, and running one."},"536":{"id":"delivery-methods-50","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#native-xlm","content":"Sent via `CreateAccount` (falling back to `Payment` if the account already exists). The amount **must be strictly greater than 1 XLM**, since below that the account cannot meet its base reserve. Otherwise you get `MinimumAmountError`."},"537":{"id":"delivery-methods-51","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#native-xlm","content":"Claiming:"},"538":{"id":"delivery-methods-52","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#native-xlm","content":"**Full sweep** (default, `merge: true`): `AccountMerge` delivers the entire balance including the reserve to your destination."},"539":{"id":"delivery-methods-53","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#native-xlm","content":"**Partial** (`merge: false`): a `Payment` that leaves the account open. The account must retain &#x2A;*2× the base reserve (1.0 XLM)** plus the fee; an over-large request throws `ClaimAmountError` with the maximum named."},"540":{"id":"delivery-methods-54","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#native-xlm","content":"Either can be relayer fee-bumped."},"541":{"id":"delivery-methods-55","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"One transaction with two operations: `CreateAccount(stealth, 1.5001 XLM)` to open the account with trustline headroom, then `CreateClaimableBalance(asset, amount, claimant: stealth)`. The sender fronts those reserves:"},"542":{"id":"delivery-methods-56","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Portion"},"543":{"id":"delivery-methods-57","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Purpose"},"544":{"id":"delivery-methods-58","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"\\~1 XLM"},"545":{"id":"delivery-methods-59","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Base account reserve"},"546":{"id":"delivery-methods-60","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"\\~0.5 XLM"},"547":{"id":"delivery-methods-61","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Trustline reserve headroom"},"548":{"id":"delivery-methods-62","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"\\~0.0001 XLM"},"549":{"id":"delivery-methods-63","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Fee slack"},"550":{"id":"delivery-methods-64","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"The 0.5 XLM claimable-balance reserve returns to the **sender** when the balance is claimed."},"551":{"id":"delivery-methods-65","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"Claiming a token has two paths:"},"552":{"id":"delivery-methods-66","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"**Self-funded** (the stealth account exists and can pay): `ChangeTrust` → `ClaimClaimableBalance` → (optional full exit: `Payment` → `ChangeTrust(limit 0)` → `AccountMerge`)."},"553":{"id":"delivery-methods-67","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"**Sponsored** (`sponsored: true`, or automatically when the account stub is missing): the relayer fronts the reserves under a **sponsorship sandwich** (`BeginSponsoringFutureReserves` … `EndSponsoringFutureReserves`) and co-signs, so you can cash out to a **fresh, unfunded address**. See Relayer."},"554":{"id":"delivery-methods-68","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#tokens-usdc-and-friends","content":"**Requirement:** the destination must already **trust the asset**, or you get `DestinationTrustlineError` before anything is submitted."},"555":{"id":"delivery-methods-69","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#auto--letting-the-client-choose","content":"`method: 'auto'` is not a third method; it resolves to a real one at call time:"},"556":{"id":"delivery-methods-70","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#auto--letting-the-client-choose","content":"> native asset **AND** amount > 1 **AND** `'account'&#x60; enabled → &#x2A;*`account`*&#x2A;; otherwise → &#x2A;*`pool`**."},"557":{"id":"delivery-methods-71","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#auto--letting-the-client-choose","content":"There is deliberately **no implicit default**: every `send()` must pass a method (or `'auto'`), or it throws `MethodRequiredError`. The privacy trade-off should always be a conscious choice."},"558":{"id":"delivery-methods-72","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"If you want…"},"559":{"id":"delivery-methods-73","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"Use"},"560":{"id":"delivery-methods-74","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"To send a token without the sender fronting \\~1.5 XLM"},"561":{"id":"delivery-methods-75","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"`pool`"},"562":{"id":"delivery-methods-76","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"To claim without ever having a funded account"},"563":{"id":"delivery-methods-77","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"`pool` (fee-bumped) or `account` + sponsored claim"},"564":{"id":"delivery-methods-78","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"Compatibility with plain Horizon tooling"},"565":{"id":"delivery-methods-79","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"`account`"},"566":{"id":"delivery-methods-80","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"Simple XLM transfer with a familiar on-chain shape"},"567":{"id":"delivery-methods-81","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#choosing","content":"`account`"},"568":{"id":"delivery-methods-82","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#next-steps","content":"Core Concepts: what a view tag and announcement actually are"},"569":{"id":"delivery-methods-83","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#next-steps","content":"Architecture: the data flow behind each method"},"570":{"id":"delivery-methods-84","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#next-steps","content":"SDK Reference: `SendOpts` / `ClaimOpts` for each method"},"571":{"id":"delivery-methods-85","page_id":"delivery-methods","tags":[],"type":"text","url":"/docs/delivery-methods#next-steps","content":"Relayer: fee-bumping and sponsored claims"},"572":{"id":"faq","page_id":"faq","type":"page","content":"FAQ & Troubleshooting","breadcrumbs":["Documentation","Trust"],"tags":[],"url":"/docs/faq"},"573":{"id":"faq-0","page_id":"faq","tags":[],"type":"text","url":"/docs/faq","content":"Common Shade questions and an error-by-error guide: what each typed error means, why it fired, and how to fix it."},"574":{"id":"faq-1","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#faq","content":"FAQ"},"575":{"id":"faq-2","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#is-shade-a-mixer","content":"Is Shade a mixer?"},"576":{"id":"faq-3","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#can-i-send-money-directly-to-a-meta-address","content":"Can I send money directly to a meta-address?"},"577":{"id":"faq-4","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#does-the-money-go-to-my-real-account","content":"Does the money go to my real account?"},"578":{"id":"faq-5","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#do-i-need-a-funded-account-to-receive-money","content":"Do I need a funded account to receive money?"},"579":{"id":"faq-6","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#can-i-claim-to-a-brand-new-empty-address","content":"Can I claim to a brand-new, empty address?"},"580":{"id":"faq-7","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#is-my-keystore-encrypted","content":"Is my keystore encrypted?"},"581":{"id":"faq-8","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#can-i-revoke-a-view-key-i-shared","content":"Can I revoke a view key I shared?"},"582":{"id":"faq-9","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#is-this-safe-for-mainnet","content":"Is this safe for mainnet?"},"583":{"id":"faq-10","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#troubleshooting-by-error","content":"Troubleshooting by error"},"584":{"id":"faq-11","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#methodrequirederror","content":"`MethodRequiredError`"},"585":{"id":"faq-12","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#contractidrequirederror","content":"`ContractIdRequiredError`"},"586":{"id":"faq-13","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#methodnotenablederror","content":"`MethodNotEnabledError`"},"587":{"id":"faq-14","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#methodnotavailableerror","content":"`MethodNotAvailableError`"},"588":{"id":"faq-15","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#minimumamounterror","content":"`MinimumAmountError`"},"589":{"id":"faq-16","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#claimamounterror","content":"`ClaimAmountError`"},"590":{"id":"faq-17","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#nobalanceerror","content":"`NoBalanceError`"},"591":{"id":"faq-18","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#announcementnotfounderror","content":"`AnnouncementNotFoundError`"},"592":{"id":"faq-19","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#stealthaccountnotfounderror","content":"`StealthAccountNotFoundError`"},"593":{"id":"faq-20","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#destinationtrustlineerror","content":"`DestinationTrustlineError`"},"594":{"id":"faq-21","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#feepayerrequirederror","content":"`FeePayerRequiredError`"},"595":{"id":"faq-22","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#feepayeraddressrequirederror","content":"`FeePayerAddressRequiredError`"},"596":{"id":"faq-23","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#sponsoredclaimmismatcherror","content":"`SponsoredClaimMismatchError`"},"597":{"id":"faq-24","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#entryarchivedrestoringerror","content":"`EntryArchivedRestoringError`"},"598":{"id":"faq-25","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#transactionretryableerror","content":"`TransactionRetryableError`"},"599":{"id":"faq-26","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#wrongpassworderror--keystore-is-encrypted-but-no-password-provided","content":"`WrongPasswordError` / \"Keystore is encrypted but no password provided\""},"600":{"id":"faq-27","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#stdin-closed-before-input-was-received","content":"\"stdin closed before input was received\""},"601":{"id":"faq-28","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#sessionintegrityerror","content":"`SessionIntegrityError`"},"602":{"id":"faq-29","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#invalidmetaaddress","content":"`InvalidMetaAddress`"},"603":{"id":"faq-30","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#common-non-error-problems","content":"Common non-error problems"},"604":{"id":"faq-31","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#i-scanned-but-see-nothing","content":"\"I scanned but see nothing\""},"605":{"id":"faq-32","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#balance-shows-less-than-scan-found","content":"\"`balance` shows less than `scan` found\""},"606":{"id":"faq-33","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#my-withdraw-signature-is-rejected-by-the-contract","content":"\"My withdraw signature is rejected by the contract\""},"607":{"id":"faq-34","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#the-relayer-returns-402-insufficient_credit","content":"\"The relayer returns 402 `insufficient_credit`\""},"608":{"id":"faq-35","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#the-relayer-returns-401","content":"\"The relayer returns 401\""},"609":{"id":"faq-36","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#the-relayer-returns-429","content":"\"The relayer returns 429\""},"610":{"id":"faq-37","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#my-keys-dont-match-between-the-cli-and-the-sdk","content":"\"My keys don't match between the CLI and the SDK\""},"611":{"id":"faq-38","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#different-keys-every-time-i-derive-from-my-wallet","content":"\"Different keys every time I derive from my wallet\""},"612":{"id":"faq-39","page_id":"faq","type":"heading","tags":[],"url":"/docs/faq#next-steps","content":"Next steps"},"613":{"id":"faq-40","page_id":"faq","tags":[],"type":"text","url":"/docs/faq","content":"\\{/\\* adapted from shade\\@36217c4 docs/10-faq-troubleshooting.md \\*/}"},"614":{"id":"faq-41","page_id":"faq","tags":[],"type":"text","url":"/docs/faq","content":"Common questions, and an error-by-error guide to what went wrong and how to fix it."},"615":{"id":"faq-42","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#is-shade-a-mixer","content":"**No.** Each stealth key has its own isolated balance in the pool contract, and both the deposit and the withdrawal name that same key on-chain. The *flow* of funds stays traceable. Shade hides **who** the recipient is, not that money moved."},"616":{"id":"faq-43","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#can-i-send-money-directly-to-a-meta-address","content":"No. A meta-address is not a Stellar account; it's just two public keys bundled together. Senders use it to *compute* a fresh one-time stealth address for each payment."},"617":{"id":"faq-44","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#does-the-money-go-to-my-real-account","content":"No. In the `pool` method funds sit in the contract, keyed by a one-time stealth public key derived from your meta-address. Your real address only appears when *you* choose it as a withdrawal destination. That's why it should be a fresh address, and why the relayer should pay the fee."},"618":{"id":"faq-45","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#do-i-need-a-funded-account-to-receive-money","content":"For the `pool` method, **no**. You don't even need a Stellar account, since the contract authorizes withdrawals by signature. You do need *someone* to pay the Soroban fee: either your own fee-payer account, or a relayer fee-bump (the private option)."},"619":{"id":"faq-46","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#do-i-need-a-funded-account-to-receive-money","content":"For the `account` method the one-time account is created and funded by the **sender** (\\~1 XLM base reserve, or \\~1.5 XLM for tokens). You get the reserve back on a full `AccountMerge` sweep."},"620":{"id":"faq-47","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#can-i-claim-to-a-brand-new-empty-address","content":"For a token claim, yes: use a relayer **sponsored claim** (`--sponsored`), where the relayer fronts the reserves and the token is paid to your destination in the same transaction. For a pool withdraw, the destination must already exist as a Stellar account."},"621":{"id":"faq-48","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#is-my-keystore-encrypted","content":"**Yes, by default** (AES-256-GCM). You only get a plaintext keystore if you explicitly pass `--plaintext` / `--no-encrypt`."},"622":{"id":"faq-49","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#can-i-revoke-a-view-key-i-shared","content":"**No.** There is no revocation. Generate new keys and publish a new meta-address. Note that old payments stay visible to the old viewer."},"623":{"id":"faq-50","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#is-this-safe-for-mainnet","content":"**No.** The project has not had an external cryptographic audit. See Security."},"624":{"id":"faq-51","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#methodrequirederror","content":"> A delivery method is required. Pass `opts.method: 'pool' | 'account' | 'auto'`."},"625":{"id":"faq-52","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#methodrequirederror","content":"There is deliberately no implicit default; the privacy trade-off must be a conscious choice. Pass `method` (CLI: `--method`). Use `'auto'` to let the client pick."},"626":{"id":"faq-53","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#contractidrequirederror","content":"The `pool` method is enabled but no contract id resolved. There is no built-in default on any network:"},"627":{"id":"faq-54","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#contractidrequirederror","content":"**SDK:** pass `contractId: 'C...'` in `ClientConfig`."},"628":{"id":"faq-55","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#contractidrequirederror","content":"**CLI:** deploy the contract and write its id to `~/.stealth/<network>-contract`."},"629":{"id":"faq-56","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#methodnotenablederror","content":"The method isn't in `config.methods`. Add it: `methods: ['pool', 'account']`."},"630":{"id":"faq-57","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#methodnotavailableerror","content":"You called the deprecated `withdraw()` without the `pool` method enabled."},"631":{"id":"faq-58","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#minimumamounterror","content":"An account-method XLM send must be **strictly greater than 1 XLM**. Below that the new account can't meet its base reserve. Send more, or use `method: 'pool'`, which has no such floor."},"632":{"id":"faq-59","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#claimamounterror","content":"A partial account claim asked for more than the account can pay out while keeping &#x2A;*2× the base reserve (1.0 XLM)** and covering the fee. The error carries `.max`. Retry within it, or do a full sweep (`merge: true` / drop `--no-merge`)."},"633":{"id":"faq-60","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#nobalanceerror","content":"The stealth address holds nothing in the pool **for that asset**. Either it was already withdrawn, or you're querying the wrong asset. Pass the right `--asset` / `opts.asset`."},"634":{"id":"faq-61","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#announcementnotfounderror","content":"No announcement matching that stealth address was found for your keys. Causes:"},"635":{"id":"faq-62","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#announcementnotfounderror","content":"The payment isn't yours."},"636":{"id":"faq-63","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#announcementnotfounderror","content":"The deposit hasn't landed/indexed yet. Wait and rescan."},"637":{"id":"faq-64","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#announcementnotfounderror","content":"(`balance`, `withdraw` and `scan` all page the full announcement set, so a high announcement index is *not* a cause.)"},"638":{"id":"faq-65","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#stealthaccountnotfounderror","content":"The stealth account isn't on Horizon yet, usually because the funding send hasn't confirmed. Wait and retry."},"639":{"id":"faq-66","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#destinationtrustlineerror","content":"The destination doesn't (or can't yet) trust the asset you're claiming. &#x2A;*Add the trustline on the destination account before claiming.** If the destination doesn't exist at all, fund it first."},"640":{"id":"faq-67","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#feepayerrequirederror","content":"A pool withdraw needs an account to pay the Soroban fee, and none was supplied. Pass `feePayer` (CLI: `--fee-payer`, or better `$SHADE_FEE_PAYER`), or route through a relayer with `--relay`."},"641":{"id":"faq-68","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#feepayeraddressrequirederror","content":"You set an external signer (`signTransaction`) on a pool claim but didn't pass `feePayerAddress&#x60;. With external signing the fee payer is identified by its **`G...` address**, never a secret. Pass `feePayerAddress`."},"642":{"id":"faq-69","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#sponsoredclaimmismatcherror","content":"**Take this seriously.** The relayer-prepared transaction does not match the operation list the SDK re-derived from your own inputs, so the SDK refused to sign. The message names the specific mismatch (a tampered payout destination, an extra appended operation, …). &#x2A;*The relayer may be malicious.** Don't retry blindly against the same relayer."},"643":{"id":"faq-70","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#entryarchivedrestoringerror","content":"Your pool `Balance`/`Nonce` entry archived (Soroban state expiration) and the automatic `RestoreFootprintOp` failed. **Your funds are safe**; the withdraw just can't proceed until the entry is restored. The message carries the underlying cause; common ones are an unfunded fee payer or a relayer rejection. Fix that and retry."},"644":{"id":"faq-71","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#entryarchivedrestoringerror","content":"Prevention: scan periodically. `get_balance`/`get_nonce` extend a live entry's TTL back to \\~1 year on read, so a passively scanning recipient never archives."},"645":{"id":"faq-72","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#transactionretryableerror","content":"The RPC returned a non-terminal status (e.g. `TRY_AGAIN_LATER`), so **nothing landed on-chain**. Safe to retry with a fresh submission. The error carries `.retryable`."},"646":{"id":"faq-73","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#wrongpassworderror--keystore-is-encrypted-but-no-password-provided","content":"Wrong or missing keystore/session password. The CLI prompts on stderr if you omit `--password`; the SDK session throws on an AES-GCM authentication failure."},"647":{"id":"faq-74","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#stdin-closed-before-input-was-received","content":"A CLI prompt (keystore password, secret) hit end-of-file before any input arrived, typical with piped stdin or in CI. The command exits **1** with this message instead of node's old behaviour of silently exiting **0** mid-command as if it had succeeded. In non-interactive contexts, pass the value via its flag or environment variable (e.g. `--password`, `$SHADE_FEE_PAYER`)."},"648":{"id":"faq-75","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#sessionintegrityerror","content":"The public key stored in the clear doesn't match the one re-derived from the decrypted private key, so **the stored session may have been tampered with**. Don't trust the material; re-import your keys."},"649":{"id":"faq-76","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#invalidmetaaddress","content":"The meta-address failed prefix, length, hex, checksum, or on-curve/torsion validation. Check for a truncated or mistyped copy-paste."},"650":{"id":"faq-77","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#i-scanned-but-see-nothing","content":"Check `--network` matches where the payment was sent."},"651":{"id":"faq-78","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#i-scanned-but-see-nothing","content":"For the account method, the cursor is persisted, so a previous scan may have advanced past it. Try `--full-rescan`."},"652":{"id":"faq-79","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#i-scanned-but-see-nothing","content":"With an indexer configured (`--indexer` / `SHADE_INDEXER`), a **cold** scan fast-starts at the indexer's coverage start. A payment older than the indexer's coverage is found only by `--full-rescan` (SDK: `ScanOpts.exhaustive`), which walks the pre-indexer history too."},"653":{"id":"faq-80","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#i-scanned-but-see-nothing","content":"Confirm the sender used *your* meta-address (the checksum makes a corrupted one throw, but a wrong-but-valid one won't)."},"654":{"id":"faq-81","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#i-scanned-but-see-nothing","content":"Confirm the deposit transaction actually landed."},"655":{"id":"faq-82","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#balance-shows-less-than-scan-found","content":"Expected in one case: `balance` suppresses fully-swept native accounts (live balance 0). For pool announcements the two commands can't diverge, because `balance` reuses `scan`'s paged fetch and pages the full set."},"656":{"id":"faq-83","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#my-withdraw-signature-is-rejected-by-the-contract","content":"Almost always the raw-scalar footgun: you built a keypair from `recoverStealthPrivateKey`'s output via `Keypair.fromRawEd25519Seed()` (or similar), which hashes it into a *different* key. &#x2A;*Sign with `signWithStealthKey`.** See Core Concepts."},"657":{"id":"faq-84","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#my-withdraw-signature-is-rejected-by-the-contract","content":"Otherwise: check the contract id and network passphrase. The message binds both, so a signature built for one deployment/network is rejected on another."},"658":{"id":"faq-85","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#the-relayer-returns-402-insufficient_credit","content":"The relayer requires credit. Gating is on by default; an operator turns it off with `RELAYER_REQUIRE_CREDIT=0`. Top up via `POST /credit/claim` with the hash of an XLM payment to the relayer, and pass `fundingAccount` (CLI: `--funding-account`) on your requests."},"659":{"id":"faq-86","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#the-relayer-returns-401","content":"The proof-of-control challenge failed: an expired/unknown nonce (120-second TTL, single-use), an account mismatch, a signature that doesn't verify, or an `authAmount` that doesn't equal what the relayer will charge. On `/relay` the signature also binds the **inner-tx hash** and the network passphrase; a mismatch there fails too. Fetch a fresh nonce and re-sign."},"660":{"id":"faq-87","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#the-relayer-returns-429","content":"Rate limit: 10 requests/minute per IP. Back off (`Retry-After` is set)."},"661":{"id":"faq-88","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#my-keys-dont-match-between-the-cli-and-the-sdk","content":"`appId` and `keyScope` must match across every tool. Defaults are `appId = 'default'`, `keyScope = 'stealth'` in both. Note `keyScope` is deliberately **decoupled from the network**: don't pass a network name into it."},"662":{"id":"faq-89","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#different-keys-every-time-i-derive-from-my-wallet","content":"Your signer is non-deterministic. Wallet-derived keys require an RFC 8032 deterministic signer; the SDK signs twice and throws when they differ, precisely to stop you from creating unrecoverable keys."},"663":{"id":"faq-90","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#next-steps","content":"Getting Started: install and first run"},"664":{"id":"faq-91","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#next-steps","content":"CLI Reference: every flag"},"665":{"id":"faq-92","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#next-steps","content":"SDK Reference: the full error table"},"666":{"id":"faq-93","page_id":"faq","tags":[],"type":"text","url":"/docs/faq#next-steps","content":"Security: limits and assumptions"},"667":{"id":"getting-started","page_id":"getting-started","type":"page","content":"Getting Started","breadcrumbs":["Documentation","Build"],"tags":[],"url":"/docs/getting-started"},"668":{"id":"getting-started-0","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started","content":"Run Shade end-to-end on Stellar testnet: prerequisites, install, generating and funding testnet keys, deploying the Soroban contract, and your first commands."},"669":{"id":"getting-started-1","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#prerequisites","content":"Prerequisites"},"670":{"id":"getting-started-2","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#install-and-build","content":"Install and build"},"671":{"id":"getting-started-3","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#generate-and-fund-a-testnet-account","content":"Generate and fund a testnet account"},"672":{"id":"getting-started-4","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#deploying-the-contract","content":"Deploying the contract"},"673":{"id":"getting-started-5","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#your-first-commands","content":"Your first commands"},"674":{"id":"getting-started-6","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#running-the-relayer-optional","content":"Running the relayer (optional)"},"675":{"id":"getting-started-7","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#running-the-indexer-optional","content":"Running the indexer (optional)"},"676":{"id":"getting-started-8","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#using-the-sdk-instead","content":"Using the SDK instead"},"677":{"id":"getting-started-9","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#tests","content":"Tests"},"678":{"id":"getting-started-10","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#networks","content":"Networks"},"679":{"id":"getting-started-11","page_id":"getting-started","type":"heading","tags":[],"url":"/docs/getting-started#next-steps","content":"Next steps"},"680":{"id":"getting-started-12","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started","content":"\\{/\\* adapted from shade\\@36217c4 docs/05-getting-started.md \\*/}"},"681":{"id":"getting-started-13","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"682":{"id":"getting-started-14","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started","content":"Run Shade end-to-end on Stellar **testnet** in a few minutes. This page covers prerequisites, install, generating and funding testnet keys, deploying the contract, and your first commands."},"683":{"id":"getting-started-15","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#prerequisites","content":"**Node.js 20+**"},"684":{"id":"getting-started-16","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#prerequisites","content":"**Stellar CLI**, needed to build and deploy the Soroban contract and to generate/fund testnet keys"},"685":{"id":"getting-started-17","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#prerequisites","content":"**Rust toolchain**, needed to compile the contract to Wasm"},"686":{"id":"getting-started-18","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#generate-and-fund-a-testnet-account","content":"Generate a keypair and fund it from friendbot. Repeat for any accounts you need: a deployer, a sender, a fee payer."},"687":{"id":"getting-started-19","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#deploying-the-contract","content":"The script builds the contract, deploys it to testnet, and writes the resulting contract id to `~/.stealth/testnet-contract`, where the CLI will find it."},"688":{"id":"getting-started-20","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#deploying-the-contract","content":"**How the CLI resolves the contract address:** it reads `~/.stealth/<network>-contract`. There is deliberately **no built-in testnet address**. Testnet resets periodically, and a stale placeholder would only produce an opaque Soroban failure later. If the file is missing, the CLI throws an actionable error naming the exact file to write, and the SDK throws `ContractIdRequiredError`."},"689":{"id":"getting-started-21","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#deploying-the-contract","content":"If you prefer to deploy by hand instead of the script:"},"690":{"id":"getting-started-22","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#running-the-relayer-optional","content":"The relayer pays your withdrawal fee so you never reveal a funded account of your own:"},"691":{"id":"getting-started-23","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#running-the-relayer-optional","content":"Then pass `--relay http://localhost:3000` to `claim`/`withdraw`. See Relayer for endpoints, credit gating, and deployment."},"692":{"id":"getting-started-24","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#running-the-indexer-optional","content":"The announcement indexer makes account-method discovery fast. It walks the global Horizon transaction feed once for everyone, so a cold scan no longer has to:"},"693":{"id":"getting-started-25","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#running-the-indexer-optional","content":"Then pass `--indexer http://localhost:3100` to `scan`/`balance` (or set `SHADE_INDEXER`). Horizon remains the source of truth: a scan falls back to the plain Horizon walk automatically if the indexer is down. See Architecture for the trust model, endpoints, and configuration."},"694":{"id":"getting-started-26","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#using-the-sdk-instead","content":"Full API in the SDK Reference."},"695":{"id":"getting-started-27","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"Network"},"696":{"id":"getting-started-28","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"Passphrase"},"697":{"id":"getting-started-29","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"RPC"},"698":{"id":"getting-started-30","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"Horizon"},"699":{"id":"getting-started-31","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"`testnet`"},"700":{"id":"getting-started-32","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"Testnet"},"701":{"id":"getting-started-33","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"`https://soroban-testnet.stellar.org`"},"702":{"id":"getting-started-34","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"`https://horizon-testnet.stellar.org`"},"703":{"id":"getting-started-35","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#networks","content":"`testnet` is the only accepted network today. Mainnet (\"public\") is a forward-looking, post-audit addition."},"704":{"id":"getting-started-36","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#next-steps","content":"CLI Reference: every command and flag"},"705":{"id":"getting-started-37","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#next-steps","content":"SDK Reference: `StealthClient`, types, errors"},"706":{"id":"getting-started-38","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#next-steps","content":"Delivery Methods: choosing `pool` vs `account`"},"707":{"id":"getting-started-39","page_id":"getting-started","tags":[],"type":"text","url":"/docs/getting-started#next-steps","content":"FAQ & Troubleshooting: when something fails"},"708":{"id":"index","page_id":"index","type":"page","content":"Introduction","breadcrumbs":["Documentation","Learn"],"tags":[],"url":"/docs"},"709":{"id":"index-0","page_id":"index","tags":[],"type":"text","url":"/docs","content":"Shade gives every Stellar payment its own fresh, unlinkable stealth address. Publish one public handle; nobody watching the chain can tell those payments are yours."},"710":{"id":"index-1","page_id":"index","type":"heading","tags":[],"url":"/docs#the-problem-your-address-is-a-glass-mailbox","content":"The problem: your address is a glass mailbox"},"711":{"id":"index-2","page_id":"index","type":"heading","tags":[],"url":"/docs#what-shade-does-and-does-not-hide","content":"What Shade does and does not hide"},"712":{"id":"index-3","page_id":"index","type":"heading","tags":[],"url":"/docs#why-stellar-needed-a-different-design","content":"Why Stellar needed a different design"},"713":{"id":"index-4","page_id":"index","type":"heading","tags":[],"url":"/docs#who-this-is-for","content":"Who this is for"},"714":{"id":"index-5","page_id":"index","type":"heading","tags":[],"url":"/docs#whats-implemented-today","content":"What's implemented today"},"715":{"id":"index-6","page_id":"index","type":"heading","tags":[],"url":"/docs#status-pre-audit-not-for-mainnet","content":"Status: pre-audit, not for mainnet"},"716":{"id":"index-7","page_id":"index","type":"heading","tags":[],"url":"/docs#next-steps","content":"Next steps"},"717":{"id":"index-8","page_id":"index","tags":[],"type":"text","url":"/docs","content":"\\{/\\* adapted from shade\\@36217c4 docs/01-introduction.md \\*/}"},"718":{"id":"index-9","page_id":"index","tags":[],"type":"text","url":"/docs","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"719":{"id":"index-10","page_id":"index","tags":[],"type":"text","url":"/docs","content":"Shade gives every payment its own fresh, unlinkable address on Stellar. You publish **one** public handle; anyone can pay you, but nobody watching the chain can tell those payments are yours, or that they're related to each other."},"720":{"id":"index-11","page_id":"index","tags":[],"type":"text","url":"/docs","content":"This page explains what Shade is, the problem it solves, and who it's for. If you want to start using it, jump to Getting Started."},"721":{"id":"index-12","page_id":"index","tags":[],"type":"text","url":"/docs","content":"**Get Shade from npm:**"},"722":{"id":"index-13","page_id":"index","tags":[],"type":"text","url":"/docs","content":"Prefer to run it end-to-end yourself first? Clone the repo, deploy the pool contract to Stellar testnet, and walk a full send → scan → claim cycle:"},"723":{"id":"index-14","page_id":"index","tags":[],"type":"text","url":"/docs","content":"Full setup in Getting Started."},"724":{"id":"index-15","page_id":"index","tags":[],"type":"text","url":"/docs#the-problem-your-address-is-a-glass-mailbox","content":"On a normal blockchain, your address is public and permanent. Every payment to it is visible and tied to you forever. Reuse it and the whole world sees your balance and your history."},"725":{"id":"index-16","page_id":"index","tags":[],"type":"text","url":"/docs#the-problem-your-address-is-a-glass-mailbox","content":"Shade gives you a **new mailbox for every single payment**, and only *you* can tell which mailboxes are yours. You hand out one public **meta-address**; senders use it to compute a brand-new one-time address each time. On-chain, those addresses look unrelated to you and to each other."},"726":{"id":"index-17","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"This distinction is the single most important thing to understand:"},"727":{"id":"index-18","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"Three terms first, so the table below reads cleanly. Full definitions are in Core Concepts:"},"728":{"id":"index-19","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Stealth address**: the fresh one-time address a sender computes from your meta-address. On-chain it looks like any ordinary Stellar address."},"729":{"id":"index-20","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**View key**: one half of your identity. It can **find** payments sent to you, but **cannot spend** them. It's safe to delegate. The other half, the **spend key**, moves the money and never leaves you."},"730":{"id":"index-21","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Relayer**: an optional helper service that pays a transaction fee on your behalf, so claiming your money doesn't reveal a wallet of your own. See Relayer."},"731":{"id":"index-22","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Hides**"},"732":{"id":"index-23","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"*Who* the recipient is. A stealth address is unlinkable to your meta-address without your view key."},"733":{"id":"index-24","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Hides**"},"734":{"id":"index-25","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"Which funded accounts you control. A relayer can pay the transaction fee so your own wallet never appears."},"735":{"id":"index-26","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Does NOT hide**"},"736":{"id":"index-27","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"That *a* payment happened, or its amount."},"737":{"id":"index-28","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Does NOT hide**"},"738":{"id":"index-29","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"The flow of funds. Shade is **not a mixer**: a pool deposit and its withdrawal both name the same stealth key on-chain."},"739":{"id":"index-30","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Does NOT hide**"},"740":{"id":"index-31","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"Timing correlation. Withdraw right after a deposit and the link is obvious."},"741":{"id":"index-32","page_id":"index","tags":[],"type":"text","url":"/docs#what-shade-does-and-does-not-hide","content":"**Privacy here is about identity, not invisibility.** The cryptography gives you the tools; your behaviour (timing, amount patterns, address reuse) can still deanonymize you."},"742":{"id":"index-33","page_id":"index","tags":[],"type":"text","url":"/docs#why-stellar-needed-a-different-design","content":"Stellar charges a &#x2A;*minimum balance reserve (MBR)** of \\~1 XLM for every account that exists. Because Shade hands out a fresh address per payment, that reserve is the design constraint: on chains where accounts are free or negligible it wouldn't matter, but on Stellar it shapes how each delivery method carries funds."},"743":{"id":"index-34","page_id":"index","tags":[],"type":"text","url":"/docs#why-stellar-needed-a-different-design","content":"The two methods sit on opposite sides of that trade-off. The &#x2A;*`pool`** method deposits into a **Soroban pool contract*&#x2A; with per-stealth-key accounting: no new account is created and no base reserve is locked, so you pay only the Soroban transaction fee. The &#x2A;*`account`** method uses a real one-time Stellar account, which holds the \\~1 XLM base reserve, reclaimed when you sweep the account to your destination. A token send through the account method fronts a bit more (a trustline reserve on top of the base reserve), part of which returns to the sender when the payment is claimed. See Delivery Methods for the exact cost profile of each."},"744":{"id":"index-35","page_id":"index","tags":[],"type":"text","url":"/docs#who-this-is-for","content":"**People receiving payments** who don't want a public, permanent link between their identity and every incoming transfer: freelancers, donation recipients, anyone publishing a payment handle."},"745":{"id":"index-36","page_id":"index","tags":[],"type":"text","url":"/docs#who-this-is-for","content":"**Application developers** who want stealth payments without implementing elliptic-curve math or hand-building Soroban transactions. See the SDK Reference."},"746":{"id":"index-37","page_id":"index","tags":[],"type":"text","url":"/docs#who-this-is-for","content":"**Wallet and tooling builders** who want the primitives only. `@shade/crypto` is pure TypeScript with **zero** `@stellar/stellar-sdk` dependency."},"747":{"id":"index-38","page_id":"index","tags":[],"type":"text","url":"/docs#whats-implemented-today","content":"Two delivery methods: &#x2A;*`pool`** (Soroban contract; works with any **SAC** token, i.e. any asset exposed to Soroban via a *Stellar Asset Contract&#x2A;: native XLM, USDC, anything issued) and &#x2A;*`account`** (a direct one-time Stellar account, or a *claimable balance*, a pending transfer the recipient later claims). See Delivery Methods."},"748":{"id":"index-39","page_id":"index","tags":[],"type":"text","url":"/docs#whats-implemented-today","content":"A **relayer** for fee-bumping and reserve-fronting. See Relayer."},"749":{"id":"index-40","page_id":"index","tags":[],"type":"text","url":"/docs#whats-implemented-today","content":"External signing via **Freighter**, encrypted browser sessions, and wallet-signature key derivation."},"750":{"id":"index-41","page_id":"index","tags":[],"type":"text","url":"/docs#whats-implemented-today","content":"A reference **CLI** (`shade`) and a **TypeScript SDK**."},"751":{"id":"index-42","page_id":"index","tags":[],"type":"text","url":"/docs#status-pre-audit-not-for-mainnet","content":"The protocol and this implementation have **not undergone an external cryptographic audit**. Treat the project as production-track but pre-audit, and do not put mainnet value at risk. Read Security before going further."},"752":{"id":"index-43","page_id":"index","tags":[],"type":"text","url":"/docs#next-steps","content":"Core Concepts: DKSAP (the Dual-Key Stealth Address Protocol Shade is built on), view/spend keys, meta-addresses, view tags"},"753":{"id":"index-44","page_id":"index","tags":[],"type":"text","url":"/docs#next-steps","content":"Architecture: the components and how data flows between them"},"754":{"id":"index-45","page_id":"index","tags":[],"type":"text","url":"/docs#next-steps","content":"Getting Started: run it locally"},"755":{"id":"index-46","page_id":"index","tags":[],"type":"text","url":"/docs#next-steps","content":"Security: threat model, assumptions, and limits"},"756":{"id":"relayer","page_id":"relayer","type":"page","content":"Relayer","breadcrumbs":["Documentation","Build"],"tags":[],"url":"/docs/relayer"},"757":{"id":"relayer-0","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer","content":"The Shade relayer: fee-bumping, sponsored claims and the credit system. Endpoints, proof-of-control auth, configuration and operational warnings."},"758":{"id":"relayer-1","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#what-it-solves","content":"What it solves"},"759":{"id":"relayer-2","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#choosing-a-relayer","content":"Choosing a relayer"},"760":{"id":"relayer-3","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#endpoints","content":"Endpoints"},"761":{"id":"relayer-4","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#post-relay","content":"`POST /relay`"},"762":{"id":"relayer-5","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#post-sponsor","content":"`POST /sponsor`"},"763":{"id":"relayer-6","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"`POST /sponsor-claim/prepare` and `/submit`"},"764":{"id":"relayer-7","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#the-credit-system","content":"The credit system"},"765":{"id":"relayer-8","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#proof-of-control","content":"Proof of control"},"766":{"id":"relayer-9","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#the-ledger","content":"The ledger"},"767":{"id":"relayer-10","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#durable--multi-instance-state","content":"Durable & multi-instance state"},"768":{"id":"relayer-11","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#rate-limiting","content":"Rate limiting"},"769":{"id":"relayer-12","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#configuration","content":"Configuration"},"770":{"id":"relayer-13","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#running-it","content":"Running it"},"771":{"id":"relayer-14","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#railway-testnet","content":"Railway (testnet)"},"772":{"id":"relayer-15","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#operational-warnings","content":"Operational warnings"},"773":{"id":"relayer-16","page_id":"relayer","type":"heading","tags":[],"url":"/docs/relayer#next-steps","content":"Next steps"},"774":{"id":"relayer-17","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer","content":"\\{/\\* adapted from shade\\@36217c4 docs/08-relayer.md \\*/}"},"775":{"id":"relayer-18","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"776":{"id":"relayer-19","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer","content":"The relayer is the reference service (`packages/relayer`) that an app or community runs. It solves a chicken-and-egg problem: to claim your money you'd normally need a funded Stellar account to pay the fee, but *using* a funded account links it to you, undoing the privacy."},"777":{"id":"relayer-20","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer","content":"This page covers what it does, its endpoints, the credit system, configuration, and deployment."},"778":{"id":"relayer-21","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#what-it-solves","content":"**Fee-bump** (`/relay`): the relayer pays your withdrawal's fee, so you never reveal a funded account of your own. This is purely about **privacy**. The relayer sees the transaction envelope but learns nothing about your other accounts."},"779":{"id":"relayer-22","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#what-it-solves","content":"**Reserve fronting / sponsored claims** (`/sponsor`, `/sponsor-claim/*`): it fronts the \\~1 XLM account reserve (plus \\~0.5 XLM trustline reserve for tokens) so you can cash out to a **fresh, unfunded address**."},"780":{"id":"relayer-23","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#choosing-a-relayer","content":"Apps and users can hand the SDK/CLI **several** relayer URLs instead of one (`ClientConfig.relayer: string[]`, CLI `--relay a,b` or the `SHADE_RELAYERS` env var). The client then health-probes every candidate in parallel and routes each relayed submission to a healthy one, failing over on relayer faults. See SDK Reference → RelayerPool for the exact health rule and failover semantics. A candidate counts as healthy only when its `/health` reports `status: 'ok'` on the right network with a workable balance, **and** its credit gate is passable by this caller. This is where the `store`/`sharedState` fields also let a client prefer a durable (`postgres`/`redis`) deployment over a dev-fallback one."},"781":{"id":"relayer-24","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#choosing-a-relayer","content":"Selection among healthy candidates is **random by default**. That is deliberate, so a community's users spread across its relayer set instead of herding onto the first entry."},"782":{"id":"relayer-25","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#choosing-a-relayer","content":"**Credit is per-relayer.** A funding account's prepaid credit lives in one relayer's ledger. If you list several independent relayers, fund your account at each of them. A failover target where you hold no credit rejects with `402 insufficient_credit` (and the client correctly stops rather than retrying elsewhere)."},"783":{"id":"relayer-26","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Endpoint"},"784":{"id":"relayer-27","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"What it does"},"785":{"id":"relayer-28","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`GET /health`"},"786":{"id":"relayer-29","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Status, network, relayer address, balance, `requireCredit`, `maxRelayFeeXlm`, `sponsoredReserveEstimate`, `store` (`postgres`\\|`json`), `sharedState` (`redis`\\|`memory`)"},"787":{"id":"relayer-30","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`POST /relay`"},"788":{"id":"relayer-31","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Fee-bump and submit a signed transaction"},"789":{"id":"relayer-32","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`POST /sponsor`"},"790":{"id":"relayer-33","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Create a stealth account (funded `CreateAccount` from the relayer)"},"791":{"id":"relayer-34","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`POST /sponsor-claim/prepare`"},"792":{"id":"relayer-35","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Build an unsigned sponsored-claim transaction"},"793":{"id":"relayer-36","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`POST /sponsor-claim/submit`"},"794":{"id":"relayer-37","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Co-sign + submit a sponsored claim"},"795":{"id":"relayer-38","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`POST /credit/claim`"},"796":{"id":"relayer-39","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Top up credit by proving an XLM payment via `txHash`"},"797":{"id":"relayer-40","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`GET /credit/challenge`"},"798":{"id":"relayer-41","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Issue a proof-of-control nonce"},"799":{"id":"relayer-42","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"`GET /credit/:account`"},"800":{"id":"relayer-43","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#endpoints","content":"Read a credit balance"},"801":{"id":"relayer-44","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Body: `{ xdr, fundingAccount?, nonce?, signature?, authAmount? }` → `{ txHash, success: true }`"},"802":{"id":"relayer-45","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Wraps your signed inner transaction in a fee-bump and submits it."},"803":{"id":"relayer-46","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Abuse guards apply on **every** path, credit-gated or not:"},"804":{"id":"relayer-47","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Guard"},"805":{"id":"relayer-48","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Default"},"806":{"id":"relayer-49","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Max operations in the inner tx"},"807":{"id":"relayer-50","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"5 (`MAX_RELAY_OPS`); zero-op inner txs are rejected (`invalid_tx`)"},"808":{"id":"relayer-51","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Timebounds must be present, unexpired, and bounded"},"809":{"id":"relayer-52","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"≤ now + 600s (`MAX_RELAY_TIMEBOUNDS_SECONDS`); already-expired bounds are rejected up front (`invalid_timebounds`) rather than burning a submit"},"810":{"id":"relayer-53","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Memos"},"811":{"id":"relayer-54","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"**Forbidden.** A relayed withdrawal has no legitimate memo, and one could leak or tag metadata"},"812":{"id":"relayer-55","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Fetched base fee clamp"},"813":{"id":"relayer-56","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"10,000 stroops (`MAX_BASE_FEE`)"},"814":{"id":"relayer-57","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"Absolute outer fee cap"},"815":{"id":"relayer-58","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"0.1 XLM (`MAX_RELAY_FEE_XLM`)"},"816":{"id":"relayer-59","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"The outer-fee cap is enforced **before** the fee bump is built. The relayer plans the bump fee from the inner tx's own per-op demand (excluding any Soroban resource fee), so an inner fee large enough to push the outer fee over the cap gets an honest `400 fee_exceeds_cap`, while a high-but-cappable inner fee is served with a correspondingly raised bump fee. An inner tx the SDK cannot build a fee bump for at all returns `400 invalid_tx`."},"817":{"id":"relayer-60","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-relay","content":"**What you're charged.** The fee is *reserved* at the built maximum (the fee bid must be covered before submission) and *settled&#x2A; to the on-chain &#x2A;*`fee_charged`** decoded from the submit result. The difference, including Soroban resource-fee refunds on contract withdrawals, is credited back automatically in the same atomic step. Your credit history shows the full-bid debit followed by an `adjust:`-tagged credit for the refund."},"818":{"id":"relayer-61","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor","content":"Body: `{ address, startingBalance?, fundingAccount, nonce, signature }` → `{ txHash, stealthAddress }`"},"819":{"id":"relayer-62","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor","content":"Creates a stealth account with a plain funded `CreateAccount`. &#x2A;*Fail-closed by design:** this route *always* requires an authenticated funding account and *always* debits `startingBalance + fee` from its credit, regardless of `RELAYER_REQUIRE_CREDIT`, so it can never be used as a free XLM faucet. `startingBalance` is capped at `SPONSOR_MAX_XLM` (default 5)."},"820":{"id":"relayer-63","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor","content":"There is deliberately **no sponsorship sandwich** here: `EndSponsoringFutureReserves` must be signed by the sponsored account, whose key nobody holds at creation time. The sandwich lives only in `/sponsor-claim`, where the client holds the stealth key and co-signs."},"821":{"id":"relayer-64","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"**prepare**: body `{ stealthAddress, asset, balanceId, destination, amount }` → `{ xdr, expiresAt }`"},"822":{"id":"relayer-65","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"Builds a relayer-sourced, **unsigned** transaction (60-second timebounds) with this exact operation sequence:"},"823":{"id":"relayer-66","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"The payout rides in the same transaction because a stealth account created with `startingBalance: '0'` under sponsorship can never pay a fee to move the tokens itself. It also verifies up front that the destination exists and already trusts the asset."},"824":{"id":"relayer-67","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"**submit**: body `{ xdr, stealthAddress, asset, balanceId, destination, amount, fundingAccount?, nonce?, signature? }` → `{ txHash }`"},"825":{"id":"relayer-68","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"The client attaches its stealth signature and returns the XDR. The relayer then rebuilds the expected operation list from the **trusted inputs** and compares field-by-field (type, per-op source, destination, asset, amount, balanceId, sponsoredId) before adding its own signature. A client cannot mutate any operation and still pass. It also enforces a per-op fee cap (200 stroops/op), the advertised 60-second TTL, and a no-memo rule."},"826":{"id":"relayer-69","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#post-sponsor-claimprepare-and-submit","content":"The charge is `sponsoredReserveEstimate` plus the transaction fee. The fee portion, like `/relay&#x60;'s, is settled to the on-chain &#x2A;*`fee_charged`** rather than the declared maximum. The reserve portion stays charged in full: it tracks the base reserve the relayer actually locks on-chain, not a fee."},"827":{"id":"relayer-70","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"The relayer is metered so it isn't a free-for-all:"},"828":{"id":"relayer-71","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"An app sends the relayer a normal XLM payment."},"829":{"id":"relayer-72","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"It calls `POST /credit/claim` with the **transaction hash**."},"830":{"id":"relayer-73","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"The relayer checks Horizon: the transaction succeeded, is sourced by that funding account, contains native payment ops **to the relayer** whose op-source is the funding account, and hasn't already been claimed. It sums every qualifying payment op and credits that amount. (A malformed funding account is rejected with `invalid_account`, the same code the challenge endpoint uses.)"},"831":{"id":"relayer-74","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"From then on the relayer serves that app's requests, drawing the credit down."},"832":{"id":"relayer-75","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-credit-system","content":"Credit gating is **on by default on every network**, so an unconfigured deploy cannot be drained through unauthenticated `/relay` and `/sponsor-claim/submit&#x60; calls. Set &#x2A;*`RELAYER_REQUIRE_CREDIT=0`*&#x2A; to disable it or &#x2A;*`=1`** to force it on explicitly."},"833":{"id":"relayer-76","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"Fee-spending requests are authenticated by an **ed25519 challenge/response** (not an API key or HMAC):"},"834":{"id":"relayer-77","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"`GET /credit/challenge?account=G...` returns a fresh random 32-byte nonce (120-second TTL, single-use, in-memory)."},"835":{"id":"relayer-78","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"The client signs the canonical message with the funding account's key:"},"836":{"id":"relayer-79","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"The relayer verifies the signature, then **consumes** the nonce."},"837":{"id":"relayer-80","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"The signed message binds the endpoint, the account, the nonce, and the exact **amount** authorized. On `/relay` the client sends that amount in the request body as `authAmount`, and `bind` is additionally the **inner transaction hash**, so an intercepted `{nonce, signature}` cannot be paired with a different inner XDR of the same fee."},"838":{"id":"relayer-81","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"On `/relay` the signed `authAmount` is a **fee ceiling**: the client authorizes \"debit up to the relayer's advertised `maxRelayFeeXlm` for THIS inner tx\", and the relayer debits only the **actual** fee (reserved at the built bid, settled down to the on-chain `fee_charged`), rejecting anything above the ceiling with `fee_exceeds_authorization`. On `/sponsor-claim/submit` the amount is the **exact** total the relayer will charge: the prepared tx's fee plus the sponsored-reserve estimate. That reserve component is advertised in `/health&#x60; as &#x2A;*`sponsoredReserveEstimate`** (`'1.0000000'`). Clients prefer the advertised value over their own mirrored constant when computing the total they sign, so changing the estimate relayer-side no longer breaks gated sponsored claims, and a `/health` fault just falls back to the mirrored constant, never breaking the claim itself."},"839":{"id":"relayer-82","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#proof-of-control","content":"The SDK and CLI handle all of this automatically once they hold a funding signer:"},"840":{"id":"relayer-83","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"The credit ledger holds balances, consumed-deposit idempotency records, reservations, and per-funder sponsored-reserve totals. Whichever backend is in use (JSON file or Postgres, below), the accounting semantics are the same:"},"841":{"id":"relayer-84","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"All arithmetic on **BigInt stroops**, never floats."},"842":{"id":"relayer-85","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"**Concurrency-safe** reservations, so two concurrent holds against a balance that only covers one cannot both succeed (per-account async locks for the JSON file; row-level guarantees for Postgres)."},"843":{"id":"relayer-86","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"**Reserve → settle / refund** around each submit: the fee is debited *before* submission, settled on success, refunded if the submit throws. Reservations carry a unique id and a terminal state (`OUTSTANDING` / `SETTLED` / `REFUNDED`) so a replay can't refund a legitimate charge."},"844":{"id":"relayer-87","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"**Settle reconciles to the actual charge**: settle accepts the on-chain `fee_charged`, keeps `actual ≤ reserved`, and credits the remainder back in the same atomic step (an `adjust:`-tagged history credit). Still idempotent: only an `OUTSTANDING` reservation flips, exactly once, so a replay can't double-credit the remainder. If the submit result can't be parsed, the full reserved amount is settled (the pre-reconciliation behavior) rather than ever failing a landed transaction."},"845":{"id":"relayer-88","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"**Idempotent by ref** via O(1) net counters (debits minus refunds), so a duplicate is a no-op while a genuine retry after a refund still re-debits."},"846":{"id":"relayer-89","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"Consumed deposit tx hashes make credit claims idempotent."},"847":{"id":"relayer-90","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"Sponsored reserves are tracked under a per-funder ceiling (`SPONSOR_CLAIM_MAX_HELD`)."},"848":{"id":"relayer-91","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#the-ledger","content":"The **JSON-file backend** (default `./data/credit-ledger.json`, override with `CREDIT_LEDGER_PATH`) is the single-instance dev fallback, used only when `DATABASE_URL` is unset. It uses **atomic writes** (write-tmp + rename) so a crash mid-write can't corrupt it, but it lives on local disk: on an ephemeral filesystem a restart wipes it (see the warning below). For any real deploy, use Postgres."},"849":{"id":"relayer-92","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"The JSON ledger plus in-memory nonces/rate-limits are fine for a single dev instance, but they don't survive a restart on an ephemeral filesystem and can't be shared across instances. Two optional env vars swap in durable, shared backends. &#x2A;*Both fail fast (exit 1) if set but unreachable.** The relayer never silently falls back, because a configured deploy that quietly forks its money ledger onto ephemeral local disk is worse than not starting."},"850":{"id":"relayer-93","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Variable"},"851":{"id":"relayer-94","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Backs"},"852":{"id":"relayer-95","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Provider example"},"853":{"id":"relayer-96","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"`DATABASE_URL`"},"854":{"id":"relayer-97","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"The **credit ledger** (balances, consumed-deposit idempotency, reservations), durable across restarts and shared across instances"},"855":{"id":"relayer-98","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Postgres (Neon / Supabase free tier); pass the **pooled** URL with `sslmode=require`"},"856":{"id":"relayer-99","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"`REDIS_URL`"},"857":{"id":"relayer-100","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"**Challenge nonces + rate-limit buckets** shared fleet-wide (a nonce is single-use across the whole fleet; one rate bucket per client)"},"858":{"id":"relayer-101","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Redis (Upstash); `rediss://` URL"},"859":{"id":"relayer-102","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"`PGPOOL_MAX`"},"860":{"id":"relayer-103","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Max Postgres pool connections (free tiers cap low)"},"861":{"id":"relayer-104","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"default `5`"},"862":{"id":"relayer-105","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"**`DATABASE_URL` (Postgres).** The schema **auto-migrates on boot** (or run `npm run migrate`). A background **reservation-recovery job** refunds stale `OUTSTANDING` holds so a crash between reserve and settle can't strand credit. Unset → the JSON-file ledger above."},"863":{"id":"relayer-106","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"**`REDIS_URL` (Redis).** With Redis, nonce single-use and the rate limit hold across every instance. Unset → in-process memory (single instance only)."},"864":{"id":"relayer-107","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"**`store` / `sharedState` in `/health`** report which backend is live (`postgres`|`json`, `redis`|`memory`) so a client can prefer a durable, multi-instance relayer."},"865":{"id":"relayer-108","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#durable--multi-instance-state","content":"Unset both and you get the JSON-file ledger plus in-memory nonces/limits, a fine single-instance dev fallback. The ephemeral-filesystem warning still fires when credit gating is on."},"866":{"id":"relayer-109","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#rate-limiting","content":"A token bucket: **10 requests/minute per client**, `429` with `Retry-After` when empty."},"867":{"id":"relayer-110","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#rate-limiting","content":"Client identity comes from the direct IP by default. `X-Forwarded-For` is only trusted when you explicitly declare proxies via `TRUST_PROXY_HOPS`, and even then hops are counted **from the right** (the entries your own infrastructure appended), so a client cannot forge extra left-hand entries to mint a fresh bucket per request."},"868":{"id":"relayer-111","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Variable"},"869":{"id":"relayer-112","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Default"},"870":{"id":"relayer-113","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Purpose"},"871":{"id":"relayer-114","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`RELAYER_SECRET`"},"872":{"id":"relayer-115","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"—"},"873":{"id":"relayer-116","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Relayer secret key (`S...` of a funded account). **ALWAYS REQUIRED**: the relayer fails fast (exit 1) if unset/empty. There is no dev fallback: a randomly generated keypair is unfunded and can't pay fees."},"874":{"id":"relayer-117","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`NETWORK`"},"875":{"id":"relayer-118","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`testnet`"},"876":{"id":"relayer-119","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Target network. Defaults to `testnet`; &#x2A;*rejects unknown values (incl. the removed `local`)** with exit 1. Mainnet (`public`) is added post-audit."},"877":{"id":"relayer-120","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`PORT`"},"878":{"id":"relayer-121","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`3000`"},"879":{"id":"relayer-122","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Listen port"},"880":{"id":"relayer-123","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`RELAYER_REQUIRE_CREDIT`"},"881":{"id":"relayer-124","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"on (all networks)"},"882":{"id":"relayer-125","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Require prepaid credit for `/relay` and `/sponsor-claim/submit`. **On by default on every network**; set `0` to disable, `1` to force on."},"883":{"id":"relayer-126","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`DATABASE_URL`"},"884":{"id":"relayer-127","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"—"},"885":{"id":"relayer-128","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Postgres URL (pooled, `sslmode=require`) backing the **credit ledger**, durable + shared across instances. Auto-migrates on boot. Set-but-unreachable → exit 1 (never a silent JSON fallback). Unset → JSON-file ledger."},"886":{"id":"relayer-129","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`REDIS_URL`"},"887":{"id":"relayer-130","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"—"},"888":{"id":"relayer-131","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Redis (`rediss://`) URL backing **challenge nonces + rate-limit buckets** shared fleet-wide. Set-but-unreachable → exit 1. Unset → in-memory (single instance)."},"889":{"id":"relayer-132","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`PGPOOL_MAX`"},"890":{"id":"relayer-133","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`5`"},"891":{"id":"relayer-134","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Max Postgres pool connections (free tiers cap low)"},"892":{"id":"relayer-135","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`CREDIT_LEDGER_PATH`"},"893":{"id":"relayer-136","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`./data/credit-ledger.json`"},"894":{"id":"relayer-137","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"JSON-ledger file path (dev fallback; used only when `DATABASE_URL` is unset). **Point at a mounted persistent volume**: the default is ephemeral on Railway (see warning below)."},"895":{"id":"relayer-138","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`TRUST_PROXY_HOPS`"},"896":{"id":"relayer-139","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`0`"},"897":{"id":"relayer-140","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Trusted reverse-proxy hops, counted from the right"},"898":{"id":"relayer-141","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`TRUST_PROXY`"},"899":{"id":"relayer-142","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"—"},"900":{"id":"relayer-143","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Legacy: `true` → 1 hop"},"901":{"id":"relayer-144","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`SPONSOR_MAX_XLM`"},"902":{"id":"relayer-145","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`5`"},"903":{"id":"relayer-146","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Cap on `/sponsor` starting balance"},"904":{"id":"relayer-147","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`SPONSOR_CLAIM_MAX_HELD`"},"905":{"id":"relayer-148","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`10`"},"906":{"id":"relayer-149","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Per-funder sponsored-reserve ceiling"},"907":{"id":"relayer-150","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`MAX_RELAY_OPS`"},"908":{"id":"relayer-151","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`5`"},"909":{"id":"relayer-152","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Max ops in a relayed inner tx"},"910":{"id":"relayer-153","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`MAX_BASE_FEE`"},"911":{"id":"relayer-154","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`10000`"},"912":{"id":"relayer-155","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Clamp on the fetched base fee (stroops)"},"913":{"id":"relayer-156","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`MAX_RELAY_FEE_XLM`"},"914":{"id":"relayer-157","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`0.1`"},"915":{"id":"relayer-158","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Absolute outer fee cap"},"916":{"id":"relayer-159","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`MAX_RELAY_TIMEBOUNDS_SECONDS`"},"917":{"id":"relayer-160","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`600`"},"918":{"id":"relayer-161","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Max future window for the inner tx `maxTime`"},"919":{"id":"relayer-162","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`CORS_ORIGIN`"},"920":{"id":"relayer-163","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`*`"},"921":{"id":"relayer-164","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Allowed origin"},"922":{"id":"relayer-165","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"`DEBUG`"},"923":{"id":"relayer-166","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"—"},"924":{"id":"relayer-167","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#configuration","content":"Enable debug logs"},"925":{"id":"relayer-168","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#running-it","content":"The relayer is deployed from a clone of the Shade repository:"},"926":{"id":"relayer-169","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"The relayer ships ready for Railway (`packages/relayer/railway.json`: NIXPACKS build, `npm run start` → `node dist/index.js`, health check on `/health`)."},"927":{"id":"relayer-170","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"Fund a testnet account via friendbot"},"928":{"id":"relayer-171","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"Set `RELAYER_SECRET` to its secret and `NETWORK=testnet`"},"929":{"id":"relayer-172","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"Point Railway's root at `packages/relayer`"},"930":{"id":"relayer-173","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"Deploy and hit `/health`"},"931":{"id":"relayer-174","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#railway-testnet","content":"Step-by-step lives in `packages/relayer/README.md`."},"932":{"id":"relayer-175","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"Read these before running a relayer with real value:"},"933":{"id":"relayer-176","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"**Authentication is on by default on every network.** `/relay` and `/sponsor-claim/submit` require credit whenever `RELAYER_REQUIRE_CREDIT` is unset (it defaults on). If you explicitly set `RELAYER_REQUIRE_CREDIT=0` on a funded deployment, those endpoints perform **no authentication**: anyone can make the relayer pay fees (and front \\~1 XLM reserves) for any conforming transaction, bounded only by an in-memory per-IP rate limit, which across many IPs is a hot-wallet drain vector. &#x2A;*Do not disable credit on a deployment that holds meaningful funds.** (`/sponsor` is fail-closed and always authenticated.)"},"934":{"id":"relayer-177","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"**The JSON ledger file is not durable on ephemeral filesystems.** When you use the JSON fallback (`DATABASE_URL` unset), a Railway redeploy or restart wipes credit balances *and* the consumed-tx records, meaning a previously claimed deposit could be re-claimed afterwards. The relayer **warns loudly at startup** when credit is enabled and `CREDIT_LEDGER_PATH` looks ephemeral (unset or under `./data`). Point it at a mounted persistent volume, or (the full production fix) set `DATABASE_URL` for a durable Postgres ledger (see Durable & multi-instance state)."},"935":{"id":"relayer-178","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"**In-memory nonces and rate-limit buckets are single-node.** Without `REDIS_URL`, horizontal scaling breaks both the rate limit and the single-use nonce guarantee, and a restart invalidates all outstanding nonces. Set `REDIS_URL` to share both fleet-wide."},"936":{"id":"relayer-179","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"**`/sponsor-claim/prepare` is unauthenticated** and performs 2–3 Horizon lookups per call, a cheap amplification surface protected only by the rate limit."},"937":{"id":"relayer-180","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#operational-warnings","content":"**`CORS_ORIGIN` defaults to `*`.** The relayer warns at startup whenever it is `*&#x60;; set it to your app origin. And **`RELAYER_SECRET` is always required**: the relayer fails fast (exit 1) if it is unset/empty, rather than ever booting an unfunded random keypair."},"938":{"id":"relayer-181","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#next-steps","content":"Delivery Methods: when a claim needs the relayer"},"939":{"id":"relayer-182","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#next-steps","content":"SDK Reference: the typed `RelayerClient`"},"940":{"id":"relayer-183","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#next-steps","content":"Security: the relayer's place in the threat model"},"941":{"id":"relayer-184","page_id":"relayer","tags":[],"type":"text","url":"/docs/relayer#next-steps","content":"FAQ & Troubleshooting: relayer errors"},"942":{"id":"sdk","page_id":"sdk","type":"page","content":"SDK Reference","breadcrumbs":["Documentation","Build"],"tags":[],"url":"/docs/sdk"},"943":{"id":"sdk-0","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"The stellar-shade and @shade/crypto API: StealthClient, types, typed errors, Freighter signing, encrypted sessions and the stealth-address primitives."},"944":{"id":"sdk-1","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#quick-start","content":"Quick start"},"945":{"id":"sdk-2","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#stealthclient","content":"`StealthClient`"},"946":{"id":"sdk-3","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#constructor","content":"Constructor"},"947":{"id":"sdk-4","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#static-methods","content":"Static methods"},"948":{"id":"sdk-5","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#send","content":"`send`"},"949":{"id":"sdk-6","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#scan--scanwithcursor","content":"`scan` / `scanWithCursor`"},"950":{"id":"sdk-7","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#balance","content":"`balance`"},"951":{"id":"sdk-8","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#claim","content":"`claim`"},"952":{"id":"sdk-9","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#withdraw-deprecated","content":"`withdraw` (deprecated)"},"953":{"id":"sdk-10","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#types-stellar-shade","content":"Types (`stellar-shade`)"},"954":{"id":"sdk-11","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#sendopts","content":"`SendOpts`"},"955":{"id":"sdk-12","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#claimopts","content":"`ClaimOpts`"},"956":{"id":"sdk-13","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#external-signing-freighter","content":"External signing (Freighter)"},"957":{"id":"sdk-14","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#wallet-derived-keys","content":"Wallet-derived keys"},"958":{"id":"sdk-15","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#sessions-stealthsession","content":"Sessions (`StealthSession`)"},"959":{"id":"sdk-16","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#relayerclient","content":"`RelayerClient`"},"960":{"id":"sdk-17","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#relayerpool","content":"`RelayerPool`"},"961":{"id":"sdk-18","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#indexerclient","content":"`IndexerClient`"},"962":{"id":"sdk-19","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#typed-errors","content":"Typed errors"},"963":{"id":"sdk-20","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#helpers","content":"Helpers"},"964":{"id":"sdk-21","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#shadecrypto","content":"`@shade/crypto`"},"965":{"id":"sdk-22","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#types","content":"Types"},"966":{"id":"sdk-23","page_id":"sdk","type":"heading","tags":[],"url":"/docs/sdk#next-steps","content":"Next steps"},"967":{"id":"sdk-24","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"\\{/\\* adapted from shade\\@36217c4 docs/07-sdk-reference.md \\*/}"},"968":{"id":"sdk-25","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"import \\{ Callout } from 'fumadocs-ui/components/callout';"},"969":{"id":"sdk-26","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"Two packages ship for application developers:"},"970":{"id":"sdk-27","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"**`@shade/crypto`**: pure stealth-address math (keys, scanning, recovery, HD/mnemonic). **Zero** Stellar dependency; usable anywhere."},"971":{"id":"sdk-28","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"**`stellar-shade`**: the batteries-included client. It wraps all Horizon/Soroban I/O behind `StealthClient`, so you never touch DKSAP math or transaction XDR."},"972":{"id":"sdk-29","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk","content":"Every symbol on this page is exported from the package named in its heading."},"973":{"id":"sdk-30","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#constructor","content":"A `relayer` **list** enables BYO-relayer discovery: relayed submissions health-probe every candidate in parallel, route to a healthy one, and fail over on relayer faults (see `RelayerPool`). A single string behaves as it always has, with no probing and no new traffic. `relayerSelection` defaults to `'random'`, spreading users across the relayer set instead of herding onto the first entry."},"974":{"id":"sdk-31","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#constructor","content":"`indexerUrl` points `scan`/`balance` at an announcement indexer, so the account method consumes its pre-extracted candidate feed (operations inlined, no per-tx Horizon round-trip) instead of walking every Horizon transaction. Horizon remains the source of truth: the scan verifies the indexer's `/health` coverage first, falls back to the pure Horizon walk automatically when the indexer is unreachable, unhealthy, or on the wrong network, and always finishes with a Horizon tail so indexer lag cannot hide a payment."},"975":{"id":"sdk-32","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#constructor","content":"`network` resolves through a single `NETWORKS` table (`packages/sdk/src/soroban.ts`); adding a network there, e.g. mainnet (`public`) after the audit, widens the accepted type automatically. Today the only entry is `testnet`."},"976":{"id":"sdk-33","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#constructor","content":"Throws &#x2A;*`ContractIdRequiredError`** if `'pool'` is enabled and no contract id resolves. This fails loudly here instead of surfacing an opaque Soroban error on the first pool call."},"977":{"id":"sdk-34","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#static-methods","content":"Both are offline, with no network needed. `fromMnemonic()` generates a phrase when called with no argument and returns it alongside the keys for backup."},"978":{"id":"sdk-35","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#send","content":"A method is **required** on every call. Throws `MethodRequiredError` if `opts.method` is missing, `MethodNotEnabledError` if the resolved method isn't in `config.methods`."},"979":{"id":"sdk-36","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#send","content":"With an external signer, pass the sender's **public** `G...` address in the `senderSecret` position."},"980":{"id":"sdk-37","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#scan--scanwithcursor","content":"`scan` is the simple form. `scanWithCursor` returns an updated per-method cursor to persist and pass to the next call for incremental discovery."},"981":{"id":"sdk-38","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#scan--scanwithcursor","content":"With `indexerUrl` configured, the account phase is **segmented**: a bounded Horizon pre-segment covers anything before the indexer's coverage window, the covered span consumes the indexer's pre-extracted announcements, and a Horizon tail **always** runs from the final cursor. An indexer fault mid-segment abandons the segment, and the tail covers the rest from the last good cursor (cursors are Horizon `paging_token`s, interchangeable both ways). A **cold** scan (no cursor) fast-starts at the indexer's coverage start; pass `ScanOpts.exhaustive: true` to instead walk the full Horizon history from genesis and pick up payments that predate the indexer's coverage (a no-op without an indexer, where the walk is always exhaustive)."},"982":{"id":"sdk-39","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#scan--scanwithcursor","content":"Two defenses run after the covered span. The scan &#x2A;*re-checks `/health`** (a gap recorded while the segment was being consumed discards its results, and the tail re-walks the whole span), and a final cursor that came from indexer-supplied positions with an empty tail is **clamped to the head Horizon itself reports**, so one malicious far-future cursor cannot blind future scans. Both outcomes are visible in `ScanResult.meta`."},"983":{"id":"sdk-40","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#balance","content":"Like a scan, but suppresses fully-swept/merged native accounts (live balance 0) so a spent stealth account is never reported as spendable."},"984":{"id":"sdk-41","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#claim","content":"Takes a `Payment` returned from `scan` and branches on its `method`: `'pool'` → signed withdraw; `'account'` → sweep / partial payout / sponsored claim."},"985":{"id":"sdk-42","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#claimopts","content":"Against a credit-gated relayer (the default), `fundingAccount` alone is not enough: the relayer requires a fresh challenge **signed** by that account, so pass `fundingSigner` too (any `(message) => signature` function: a raw keypair, a wallet, an HSM). Both fields also apply to `withdraw()`'s `WithdrawOpts`."},"986":{"id":"sdk-43","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#external-signing-freighter","content":"A web app should **never** hold a raw secret. Pass a signer function instead:"},"987":{"id":"sdk-44","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#external-signing-freighter","content":"**The security boundary:** the signer only ever applies to the **sender** and **fee-payer** legs, the ordinary Stellar signatures. The **stealth-key** legs always sign locally inside the SDK, because a wallet cannot hold a key it never generated. Your wallet never touches the stealth scalar."},"988":{"id":"sdk-45","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#external-signing-freighter","content":"On a pool claim with a signer you must also pass `feePayerAddress` (the fee payer's `G...`), or you get `FeePayerAddressRequiredError`. This prevents the SDK from ever calling `Keypair.fromSecret` on a public key."},"989":{"id":"sdk-46","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#wallet-derived-keys","content":"Determinism is verified **by default**. A randomized or non-canonical signer would derive different (unrecoverable) keys on every call, so it fails loudly instead. Pass `verifyDeterminism: false` only for a signer you know is RFC 8032 deterministic."},"990":{"id":"sdk-47","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#wallet-derived-keys","content":"`keyScope` / `appId` must **match across every tool** deriving from the same wallet. The defaults line up with the CLI's `--key-scope` / `--app-id`."},"991":{"id":"sdk-48","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#sessions-stealthsession","content":"Cookie-free browser sessions over any key/value store:"},"992":{"id":"sdk-49","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#sessions-stealthsession","content":"Methods: `saveKeys`, `unlock`, `lock`, `hasKeys`, `clear`, `loadScanState`, `saveScanState`; getter `keys`."},"993":{"id":"sdk-50","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#sessions-stealthsession","content":"**Crypto:** PBKDF2-SHA256 (600,000 iterations) → AES-256-GCM, via `globalThis.crypto.subtle` only (browsers and Node 18+). Public keys are stored in the clear; private keys and scan state are encrypted. This is intentionally separate from the CLI keystore (which uses Node's scrypt)."},"994":{"id":"sdk-51","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#sessions-stealthsession","content":"**Integrity:** on `unlock`, both public keys are re-derived from the decrypted private scalars and compared to the stored cleartext pubkeys, so a storage-write attacker cannot swap in a wrong pubkey and silently break scanning. Mismatch throws `SessionIntegrityError`; a bad password throws `WrongPasswordError`."},"995":{"id":"sdk-52","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Method"},"996":{"id":"sdk-53","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Purpose"},"997":{"id":"sdk-54","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`health()`"},"998":{"id":"sdk-55","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Status, balance, address, advertised fee/reserve figures (`RelayerHealth`)"},"999":{"id":"sdk-56","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`relay(xdr, opts?)`"},"1000":{"id":"sdk-57","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Fee-bump and submit a signed envelope"},"1001":{"id":"sdk-58","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`sponsor(address, opts?)`"},"1002":{"id":"sdk-59","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Create a stealth account from the relayer's balance"},"1003":{"id":"sdk-60","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`sponsorClaimPrepare(args)`"},"1004":{"id":"sdk-61","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Build the sponsored claim tx (returns unsigned XDR)"},"1005":{"id":"sdk-62","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`sponsorClaimSubmit(xdr, args)`"},"1006":{"id":"sdk-63","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Co-sign + submit a sponsored claim"},"1007":{"id":"sdk-64","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`sponsoredReserveEstimateStroops()`"},"1008":{"id":"sdk-65","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"The relayer's advertised sponsor-claim reserve (`RelayerHealth.sponsoredReserveEstimate`, a 7-dp XLM string like `'1.0000000'`) parsed to exact stroops; `undefined` when not advertised, unparsable, or `/health` is unreachable"},"1009":{"id":"sdk-66","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`creditClaim(fundingAccount, txHash)`"},"1010":{"id":"sdk-67","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Top up credit by proving an XLM payment"},"1011":{"id":"sdk-68","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"`creditBalance(fundingAccount)`"},"1012":{"id":"sdk-69","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Read a credit balance"},"1013":{"id":"sdk-70","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"A **credit-gated sponsored claim** signs its proof-of-control over the exact total the relayer debits: the prepared tx's fee **plus** the sponsored-reserve estimate. The SDK prefers the estimate the relayer advertises in `/health` and falls back to its own mirrored 1 XLM constant when `sponsoredReserveEstimateStroops()` returns `undefined`, so a relayer-side change to the estimate no longer breaks gated claims, and a `/health` fault never breaks the claim itself."},"1014":{"id":"sdk-71","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerclient","content":"Also exported: `challengeMessage(endpoint, fundingAccount, nonce, amount, bind?)`, the canonical proof-of-control message, which must match the relayer byte-for-byte. See Relayer."},"1015":{"id":"sdk-72","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"Health-probing selector and failover harness over a **list** of relayer URLs. The adapters use it internally whenever `relayer`/`relay` is a list; it is exported for apps that want direct control."},"1016":{"id":"sdk-73","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"**The health rule.** A candidate is healthy iff its `/health` reports `status: 'ok'`, its `network` doesn't contradict yours (an unreported network passes; only an explicit mismatch rejects), its `balance` is at least 1 XLM (`minBalanceXlm` overrides), and its credit gate is passable: `requireCredit === false`, **or** the call context carries `fundingAccount` + `fundingSigner`. A missing `requireCredit` counts as gated (fail-closed, matching the relayer's gating-on default)."},"1017":{"id":"sdk-74","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"**Failover.** Probes run in parallel under one \\~2.5s budget (cached 30s per pool). `withRelayer` makes at most **2 attempts** and fails over **only on relayer faults**: unreachable, 5xx, or a 10s attempt timeout. A 4xx (bad request, insufficient credit) or any non-transport error rethrows immediately, since it would only repeat. Failing over after an ambiguous timeout cannot double-spend: both attempts fee-bump the *same signed inner tx*, so its sequence number lets at most one land."},"1018":{"id":"sdk-75","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"**Single URL = pass-through.** A one-URL pool never probes and applies no timeouts, byte-identical to using `RelayerClient` directly, so single-relayer setups see no new traffic or failure modes."},"1019":{"id":"sdk-76","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"**Credit is per-relayer**: a funding account's balance lives at one relayer, so a failover target may 402 (`insufficient_credit`), which correctly stops the call rather than retrying elsewhere. Fund the account at every relayer you list, or list relayers sharing a ledger."},"1020":{"id":"sdk-77","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#relayerpool","content":"Also exported: `normalizeRelayList(relay?)`, the canonical `string | string[]` → clean-list normalization (`[]`/whitespace → `undefined`)."},"1021":{"id":"sdk-78","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"Thin HTTP client for the announcement indexer, the account method's discovery accelerator. The account adapter uses it internally whenever `ClientConfig.indexerUrl` is set; it is exported for apps that want the feed directly."},"1022":{"id":"sdk-79","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"Method"},"1023":{"id":"sdk-80","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"Purpose"},"1024":{"id":"sdk-81","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"`health()`"},"1025":{"id":"sdk-82","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"The coverage window (`cursor`, `startCursor`), `network`, `store` backend, `lagSeconds`, ingest diagnostics (`IndexerHealth`)"},"1026":{"id":"sdk-83","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"`getAnnouncements(cursor?, limit?)`"},"1027":{"id":"sdk-84","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"One page of candidates strictly after `cursor` (`AnnouncementsPage`; the service caps `limit` at 200); records carry their Horizon operation records inlined verbatim"},"1028":{"id":"sdk-85","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#indexerclient","content":"Every failure is typed so the scan can treat it as \"fall back to the Horizon walk\", never as a lost payment: transport failures and timeouts throw &#x2A;*`IndexerNetworkError`** (code `indexer_network_error&#x60;); non-2xx responses throw &#x2A;*`IndexerHttpError`** (code `indexer_http_error`), carrying the HTTP `.status` and the indexer's own `.indexerCode` from its `{ error, code }` body. Also exported: the `IndexerHealth`, `IndexerAnnouncement`, and `AnnouncementsPage` types."},"1029":{"id":"sdk-86","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"All exported from `stellar-shade&#x60; so apps can branch cleanly. Every error extends a shared &#x2A;*`ShadeError`*&#x2A; base and carries a stable &#x2A;*`code`** string (e.g. `method_required`, `transaction_timeout`); branch on `e.code` when `instanceof` is unreliable across bundling/realm boundaries:"},"1030":{"id":"sdk-87","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Error"},"1031":{"id":"sdk-88","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Thrown when"},"1032":{"id":"sdk-89","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`MethodRequiredError`"},"1033":{"id":"sdk-90","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`send()` called without `opts.method`"},"1034":{"id":"sdk-91","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`MethodNotEnabledError`"},"1035":{"id":"sdk-92","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Requested method isn't in `config.methods`"},"1036":{"id":"sdk-93","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`MethodNotAvailableError`"},"1037":{"id":"sdk-94","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Method exists but can't service the request"},"1038":{"id":"sdk-95","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`MinimumAmountError`"},"1039":{"id":"sdk-96","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Account-method XLM send ≤ 1 XLM"},"1040":{"id":"sdk-97","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`ClaimAmountError`"},"1041":{"id":"sdk-98","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Partial account claim exceeds the max (carries `.max`)"},"1042":{"id":"sdk-99","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`InvalidAmountError`"},"1043":{"id":"sdk-100","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Amount isn't a positive finite number"},"1044":{"id":"sdk-101","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`SponsoredClaimMismatchError`"},"1045":{"id":"sdk-102","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Relayer-prepared XDR doesn't match your own inputs; **refuses to sign**"},"1046":{"id":"sdk-103","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`WrongPasswordError`"},"1047":{"id":"sdk-104","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Session decryption failed"},"1048":{"id":"sdk-105","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`SessionIntegrityError`"},"1049":{"id":"sdk-106","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"Stored pubkey ≠ pubkey derived from decrypted private key"},"1050":{"id":"sdk-107","page_id":"sdk","tags":[],"type":"text","url":"/docs/sdk#typed-errors","content":"`NoBalanceError`"},"1051":